generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String
  email    String @unique
  password String
  role     String @default("user")

  // Password reset
  resetToken        String?   @db.Text
  resetTokenExpires DateTime? @db.Timestamptz(6)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  createdCosts   Cost[]          @relation("CreatedCosts")
  approvedCosts  Cost[]          @relation("ApprovedCosts")
  costApprovals  CostApproval[]  @relation("ApprovalsByUser")
  projectManager ProjectManager?
}

model Project {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  budget      Float
  startDate   DateTime  @db.Timestamptz(6)
  endDate     DateTime? @db.Timestamptz(6)
  status      String    @default("active")
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)

  // Relations
  costs                     Cost[]
  projectManagerAssignments ProjectManagerAssignment[]

  @@index([status])
}

model Cost {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // Project relation
  projectId String  @db.Uuid
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Cost details
  description   String
  amount        Float
  category      String
  date          DateTime @db.Timestamptz(6)
  status        String   @default("pending")
  invoiceNumber String?

  // Submitted by user
  submittedBy String @db.Uuid
  submitted   User   @relation("CreatedCosts", fields: [submittedBy], references: [id], onDelete: Restrict)

  // Approved by user (optional)
  approvedBy String? @db.Uuid
  approved   User?   @relation("ApprovedCosts", fields: [approvedBy], references: [id], onDelete: SetNull)

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  attachments Attachment[]
  approvals   CostApproval[]

  @@index([projectId])
  @@index([submittedBy])
  @@index([approvedBy])
  @@index([status])
  @@index([date])
}

model Attachment {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // Cost relation
  costId String @db.Uuid
  cost   Cost   @relation(fields: [costId], references: [id], onDelete: Cascade)

  // File details
  filename String
  url      String
  size     Int
  mimeType String

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@index([costId])
}

model CostApproval {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // Cost relation
  costId String @db.Uuid
  cost   Cost   @relation(fields: [costId], references: [id], onDelete: Cascade)

  // Approval details
  status  String
  comment String?

  // Approved by user
  approvedBy String @db.Uuid
  approved   User   @relation("ApprovalsByUser", fields: [approvedBy], references: [id], onDelete: Restrict)

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@index([costId])
  @@index([approvedBy])
}

model ProjectManager {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // User relation
  userId String @unique @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Manager details
  managerRole String  @default("Project Manager") // Project Manager, Senior Project Manager, Lead Project Manager
  department  String?
  phone       String?

  // Status
  status String @default("active") // active, inactive, on-leave

  // Availability
  isAvailable Boolean @default(true)
  maxProjects Int     @default(5)

  // Timestamps
  joinDate   DateTime @default(now()) @db.Timestamptz(6)
  lastActive DateTime @default(now()) @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  projectAssignments ProjectManagerAssignment[]

  @@index([userId])
  @@index([status])
  @@index([isAvailable])
}

model ProjectManagerAssignment {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // Project Manager relation
  projectManagerId String         @db.Uuid
  projectManager   ProjectManager @relation(fields: [projectManagerId], references: [id], onDelete: Cascade)

  // Project relation
  projectId String  @db.Uuid
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Assignment details
  role      String    @default("manager") // manager, co-manager, stakeholder
  startDate DateTime  @default(now()) @db.Timestamptz(6)
  endDate   DateTime?
  status    String    @default("active") // active, inactive, completed

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  // Constraints
  @@unique([projectManagerId, projectId])
  @@index([projectManagerId])
  @@index([projectId])
  @@index([status])
}
