  low
  medium
  high
  very_high
}

/// Risk status
enum RiskStatus {
  open
  mitigated
  closed
  accepted
}

// ============================================================
// GENERIC STATUS ENUM (for backward compatibility)
// ============================================================

/// Generic status enum used across multiple entities
/// This is a superset of statuses for backward compatibility
enum Status {
  todo
  in_progress
  in_review
  done
  pending
  approved
  rejected
  active
  inactive
}

/// Priority levels (for backward compatibility)
enum Priority {
  low
  medium
  high
  urgent
}

/// Leave allocation model for tracking annual leave hours
model leave_allocations {
  id                String   @id @default(cuid())
  user_id           String
  year              Int
  annual_leave_hours Decimal @db.Decimal(8, 2)
  used_leave_hours   Decimal @db.Decimal(8, 2) @default(0)
  remaining_hours    Decimal @db.Decimal(8, 2)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  users              users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  leave_requests     leave_requests[]

  @@unique([user_id, year])
  @@index([user_id])
  @@map("leave_allocations")
}

// ============================================================
// VENDOR MANAGEMENT TABLES
// ============================================================

/// Vendors table for managing vendor information and performance
model vendors {
  id                    String    @id
  name                  String
  code                  String?   @unique
  type                  VendorType
  category              VendorCategory
  status                VendorStatus @default(active)
  
  // Contact Information
  contactPerson         String?
  email                 String?
  phone                 String?
  website               String?
  
  // Business Information
  taxId                 String?
  registrationNumber    String?
  address               String?
  city                  String?
  province              String?
  postalCode            String?
  country               String?   @default("Thailand")
  
  // Financial Information
  bankAccount           String?
  bankName              String?
  paymentTerms          Int?      // days
  creditLimit           Decimal?  @db.Decimal(12, 2)
  
  // Performance & Rating
  overallRating         VendorRating @default(satisfactory)
  totalProjects         Int       @default(0)
  successfulProjects    Int       @default(0)
  averageDeliveryTime   Int?      // days
  onTimeDeliveryRate    Decimal?  @db.Decimal(5, 2) // percentage
  
  // Metadata
  notes                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime
  
  // Relations
  vendorContracts       vendor_contracts[]
  vendorPayments        vendor_payments[]
  vendorKpiEvaluations  vendor_kpi_evaluations[]
  expenseItems          expense_items[]
  
  @@index([type, status])
  @@index([category])
  @@index([overallRating])
}

/// Vendor contracts for managing vendor agreements
model vendor_contracts {
  id              String    @id
  vendorId        String
  projectId       String?
  contractNumber  String?   @unique
  title           String
  description     String?
  
  // Contract Details
  type            ContractType
  startDate       DateTime
  endDate         DateTime?
  value           Decimal   @db.Decimal(12, 2)
  currency        String    @default("THB")
  
  // Payment Terms
  paymentTerms    String?
  paymentSchedule Json?     // detailed payment schedule
  
  // Contract Status
  status          ContractStatus @default(draft)
  signedDate      DateTime?
  signedBy        String?
  
  // Metadata
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime
  
  // Relations
  vendor          vendors    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  project         projects?  @relation(fields: [projectId], references: [id])
  vendorPayments  vendor_payments[]
  
  @@index([vendorId, status])
  @@index([projectId])
}

/// Vendor payments for tracking payments to vendors
model vendor_payments {
  id                String           @id
  vendorId          String
  contractId        String?
  projectId         String?
  
  // Payment Details
  paymentType       VendorPaymentType
  amount            Decimal          @db.Decimal(12, 2)
  currency          String           @default("THB")
  dueDate           DateTime
  paidDate          DateTime?
  
  // Installment Information
  installmentNumber Int?             // for installment payments
  totalInstallments Int?             // total number of installments
  
  // Payment Status
  status            PaymentStatus    @default(pending)
  paymentMethod     PaymentMethod?
  transactionId      String?
  receiptUrl        String?
  
  // Approval Workflow
  approvedBy        String?
  approvedAt        DateTime?
  rejectedReason    String?
  
  // Metadata
  description       String?
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime
  
  // Relations
  vendor            vendors          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  contract          vendor_contracts? @relation(fields: [contractId], references: [id])
  project           projects?        @relation(fields: [projectId], references: [id])
  
  @@index([vendorId, status])
  @@index([dueDate, status])
  @@index([projectId])
}

/// Expense items for detailed expense breakdown with vendor information
model expense_items {
  id              String           @id
  expenseId       String
  vendorId        String?
  
  // Item Details
  category        ExpenseCategory
  subcategory     String?          // detailed subcategory (e.g., "laptops", "servers", "licenses")
  description     String
  quantity        Decimal          @default(1) @db.Decimal(10, 2)
  unitPrice       Decimal          @db.Decimal(12, 2)
  totalPrice      Decimal          @db.Decimal(12, 2)
  
  // Cost Breakdown
  baseCost        Decimal          @db.Decimal(12, 2)  // actual cost
  markup          Decimal          @default(0) @db.Decimal(5, 2) // percentage
  marginAmount    Decimal          @db.Decimal(12, 2)  // calculated margin
  finalPrice      Decimal          @db.Decimal(12, 2)  // price charged to client
  
  // Vendor Information
  vendorItemCode  String?          // vendor's item code/SKU
  vendorInvoice   String?          // vendor invoice number
  
  // Metadata
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime
  
  // Relations
  expense         expenses         @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  vendor          vendors?         @relation(fields: [vendorId], references: [id])
  
  @@index([expenseId])
  @@index([vendorId])
  @@index([category])
}

/// Vendor KPI evaluations for performance tracking
model vendor_kpi_evaluations {
  id              String    @id
  vendorId        String
  projectId       String?
  evaluationPeriod String   // e.g., "2024-Q1", "2024-01"
  
  // KPI Metrics (1-10 scale)
  qualityScore    Decimal   @db.Decimal(3, 1)  // Quality of deliverables
  timelinessScore Decimal   @db.Decimal(3, 1)  // On-time delivery
  costScore       Decimal   @db.Decimal(3, 1)  // Cost competitiveness
  communicationScore Decimal @db.Decimal(3, 1) // Communication & responsiveness
  technicalScore   Decimal   @db.Decimal(3, 1)  // Technical capability
  
  // Overall Metrics
  overallScore    Decimal   @db.Decimal(3, 1)
  rating          VendorRating
  
  // Evaluation Details
  evaluatorId     String
  strengths       String?   // documented strengths
  weaknesses      String?   // areas for improvement
  recommendations String?   // action items
  nextEvaluationDate DateTime?
  
  // Metadata
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime
  
  // Relations
  vendor          vendors   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  project         projects? @relation(fields: [projectId], references: [id])
  evaluator       users     @relation(fields: [evaluatorId], references: [id])
  
  @@index([vendorId, evaluationPeriod])
  @@index([projectId])
  @@index([overallScore])
}

/// Vendor KPI criteria for standardized evaluation
model vendor_kpi_criteria {
  id              String    @id
  name            String
  category        KpiCategory
  description     String
  weight          Decimal   @db.Decimal(3, 1) @default(1.0) // relative importance
  measurementUnit String?   // e.g., "days", "percentage", "score (1-10)"
  targetValue     Decimal?  @db.Decimal(10, 2)
  minValue        Decimal?  @db.Decimal(10, 2)
  maxValue        Decimal?  @db.Decimal(10, 2)
  
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime
  
  @@index([category])
  @@index([isActive])
}

/// Leave request model for tracking leave requests
model leave_requests {
  id                    String    @id @default(cuid())
  leave_allocation_id   String
  user_id               String
  start_date            DateTime
  end_date              DateTime
  leave_type            LeaveType
  reason                String
  status                Status    @default(pending)
  approved_by           String?
  approved_at           DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  leave_allocations     leave_allocations @relation(fields: [leave_allocation_id], references: [id], onDelete: Cascade)
  users                 users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  approver              users?   @relation("leave_request_approver", fields: [approved_by], references: [id])

  @@index([leave_allocation_id])
  @@index([user_id])
  @@index([status])
  @@map("leave_requests")
}

/// Time entry comment model for tracking comments on time entries
model time_entry_comments {
  id              String   @id @default(cuid())
  time_entry_id   String
  user_id         String
  text            String
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  time_entries    time_entries @relation(fields: [time_entry_id], references: [id], onDelete: Cascade)
  users           users        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([time_entry_id])
  @@map("time_entry_comments")
}
