  hardware_vendor
  software_vendor
  custom_software_vendor
  material_vendor
  service_vendor
  consulting_vendor
  maintenance_vendor
  license_vendor
}

/// Expense approval status
enum ExpenseStatus {
  pending
  approved
  rejected
  reimbursed
}

/// Payment methods for expenses
enum PaymentMethod {
  cash
  credit_card
  bank_transfer
  check
  other
}

// ============================================================
// VENDOR MANAGEMENT ENUMS
// ============================================================

/// Vendor payment types
enum VendorPaymentType {
  full_payment
  installment
  milestone_based
  recurring
  progress_based
}

/// Vendor performance rating
enum VendorRating {
  excellent
  good
  satisfactory
  needs_improvement
  poor
}

/// Vendor types
enum VendorType {
  company
  individual
  partnership
  government
}

/// Vendor business categories
enum VendorCategory {
  hardware
  software
  custom_software
  materials
  services
  consulting
  maintenance
  licensing
  other
}

/// Vendor status
enum VendorStatus {
  active
  inactive
  suspended
  blacklisted
}

/// Contract types
enum ContractType {
  fixed_price
  time_materials
  retainer
  service_agreement
  purchase_order
}

/// Contract status
enum ContractStatus {
  draft
  pending_approval
  active
  completed
  terminated
  expired
}

/// Payment status
enum PaymentStatus {
  pending
  approved
  paid
  overdue
  cancelled
  rejected
}

/// KPI categories
enum KpiCategory {
  quality
  timeliness
  cost
  communication
  technical
  compliance
  innovation
}

// ============================================================
// CLIENT ENUMS
// ============================================================

/// Client status
enum ClientStatus {
