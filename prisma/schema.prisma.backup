generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model activity_log {
  id          String       @id
  entityType  String
  entityId    String
  type        ActivityType
  action      String
  description String?
  userId      String
  changes     Json?
  createdAt   DateTime     @default(now())
  users       users        @relation(fields: [userId], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model audit_logs {
  id         String    @id
  project_id String?
  user_id    String?
  event_type String
  severity   String
  details    String?
  ip_address String?
  user_agent String?
  created_at DateTime  @default(now()) @db.Timestamp(6)
  projects   projects? @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model budget_lines {
  id                   String    @id
  project_id           String
  type                 String
  amount               Decimal   @default(0) @db.Decimal
  date                 DateTime? @db.Date
  related_milestone_id String?
  projects             projects  @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([project_id, date], map: "idx_budget_lines_project_date")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model budget_revisions {
  id             String   @id
  projectId      String
  previousBudget Decimal  @db.Decimal(12, 2)
  newBudget      Decimal  @db.Decimal(12, 2)
  reason         String
  changedBy      String
  changedAt      DateTime @default(now())
  users          users    @relation(fields: [changedBy], references: [id])
  projects       projects @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model clients {
  id        String     @id
  name      String
  email     String?
  phone     String?
  address   String?
  taxId     String?
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime
  projects  projects[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model comments {
  id        String   @id
  taskId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime
  tasks     tasks    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  users     users    @relation(fields: [userId], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model contacts {
  id            String        @id
  project_id    String
  name          String?
  position      String?
  email         String?
  phone         String?
  type          String?
  is_key_person Boolean?      @default(false)
  projects      projects      @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sales_deals   sales_deals[]

  @@index([project_id], map: "idx_contacts_project")
  @@index([type], map: "idx_contacts_type")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model documents {
  id         String    @id
  name       String
  type       String?
  size       String?
  url        String?
  projectId  String?
  taskId     String?
  uploadedBy String?
  milestone  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime
  projects   projects? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks      tasks?    @relation(fields: [taskId], references: [id])
  users      users?    @relation(fields: [uploadedBy], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model expenses {
  id                               String          @id
  date                             DateTime
  projectId                        String
  taskId                           String?
  userId                           String
  amount                           Decimal         @db.Decimal(12, 2)
  category                         ExpenseCategory
  description                      String
  receiptUrl                       String?
  status                           ExpenseStatus   @default(pending)
  approvedBy                       String?
  approvedAt                       DateTime?
  notes                            String?
  createdAt                        DateTime        @default(now())
  updatedAt                        DateTime
  rejectedReason                   String?
  details                          Json?
  approver_id                      String?
  approverId                       String?
  users_expenses_approvedByTousers users?          @relation("expenses_approvedByTousers", fields: [approvedBy], references: [id])
  users_expenses_approverIdTousers users?          @relation("expenses_approverIdTousers", fields: [approverId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "expenses_approverid_fkey")
  projects                         projects        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks                            tasks?          @relation(fields: [taskId], references: [id])
  users_expenses_userIdTousers     users           @relation("expenses_userIdTousers", fields: [userId], references: [id], onDelete: Cascade)
  expenseItems                     expense_items[]

  @@index([status, date], map: "idx_expenses_status_date")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model financial_data {
  id        String   @id
  month     DateTime @unique
  revenue   Decimal  @default(0.00) @db.Decimal(15, 2)
  cost      Decimal  @default(0.00) @db.Decimal(15, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model milestones {
  id          String    @id
  title       String
  description String?
  dueDate     DateTime
  amount      Decimal?  @db.Decimal(15, 2)
  status      String    @default("pending")
  progress    Int       @default(0)
  projectId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  name        String?
  percentage  Decimal?  @default(0.00) @db.Decimal
  projects    projects? @relation(fields: [projectId], references: [id])
  tasks       tasks[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model project_members {
  id        String   @id
  projectId String
  userId    String
  role      String   @default("member")
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime
  projects  projects @relation(fields: [projectId], references: [id], onDelete: Cascade)
  users     users    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model project_progress_history {
  id        String   @id
  projectId String
  progress  Int
  weekDate  DateTime
  createdAt DateTime @default(now())
  projects  projects @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model project_progress_snapshots {
  id             String   @id
  project_id     String
  date           DateTime @db.Date
  plan_percent   Decimal  @default(0) @db.Decimal
  actual_percent Decimal  @default(0) @db.Decimal
  spi            Decimal? @db.Decimal
  projects       projects @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([project_id, date], map: "idx_project_progress_snapshots_project_date")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model projectassignee {
  A        String
  B        String
  projects projects @relation(fields: [A], references: [id], onDelete: Cascade, map: "_ProjectAssignee_A_fkey")
  users    users    @relation(fields: [B], references: [id], onDelete: Cascade, map: "_ProjectAssignee_B_fkey")

  @@id([A, B], map: "_ProjectAssignee_AB_pkey")
  @@index([B], map: "_ProjectAssignee_B_index")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model projects {
  id                         String                       @id
  name                       String
  code                       String?                      @unique
  description                String?
  status                     Status                       @default(todo)
  progress                   Int                          @default(0)
  progressPlan               Int                          @default(0)
  spi                        Decimal                      @default(1.00) @db.Decimal(5, 2)
  riskLevel                  String                       @default("low")
  startDate                  DateTime?
  endDate                    DateTime?
  budget                     Decimal?                     @db.Decimal(12, 2)
  spent                      Decimal                      @default(0.00) @db.Decimal(12, 2)
  remaining                  Decimal                      @default(0.00) @db.Decimal(12, 2)
  managerId                  String?
  clientId                   String?
  hourlyRate                 Decimal                      @default(0.00) @db.Decimal(10, 2)
  priority                   String                       @default("medium")
  category                   String?
  isArchived                 Boolean                      @default(false)
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime
  closure_checklist          Json?
  warranty_start_date        DateTime?                    @db.Timestamp(6)
  warranty_end_date          DateTime?                    @db.Timestamp(6)
  audit_logs                 audit_logs[]
  budget_lines               budget_lines[]
  budget_revisions           budget_revisions[]
  contacts                   contacts[]
  documents                  documents[]
  expenses                   expenses[]
  milestones                 milestones[]
  project_members            project_members[]
  project_progress_history   project_progress_history[]
  project_progress_snapshots project_progress_snapshots[]
  projectassignee            projectassignee[]
  clients                    clients?                     @relation(fields: [clientId], references: [id])
  users                      users?                       @relation(fields: [managerId], references: [id])
  risks                      risks[]
  spi_cpi_daily_snapshot     spi_cpi_daily_snapshot[]
  tasks                      tasks[]
  time_entries               time_entries[]
  timesheets                 timesheets[]
  resource_allocations       resource_allocations[]
  vendorContracts            vendor_contracts[]
  vendorPayments             vendor_payments[]
  vendorKpiEvaluations       vendor_kpi_evaluations[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model risks {
  id             String    @id
  title          String
  description    String?
  impact         String
  probability    String
  riskScore      Int?
  mitigationPlan String?
  status         String    @default("open")
  projectId      String?
  assignedTo     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime
  users          users?    @relation(fields: [assignedTo], references: [id])
  projects       projects? @relation(fields: [projectId], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model sales_activities {
  id          String      @id
  deal_id     String
  type        String
  note        String?
  user_id     String?
  createdat   DateTime    @default(now()) @db.Timestamp(6)
  sales_deals sales_deals @relation(fields: [deal_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users       users?      @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model sales_deals {
  id               String             @id
  name             String
  amount           Decimal            @default(0) @db.Decimal(14, 2)
  currency         String             @default("THB")
  pipeline_id      String?
  stage_id         String?
  owner_id         String?
  client_id        String?
  client_org       String?
  status           String             @default("open")
  probability      Int                @default(0)
  createdat        DateTime?          @default(now()) @db.Timestamptz(6)
  updatedat        DateTime?          @default(now()) @db.Timestamptz(6)
  createdAt        DateTime?          @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime?          @default(now()) @db.Timestamptz(6)
  sales_activities sales_activities[]
  contacts         contacts?          @relation(fields: [client_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users            users?             @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sales_pipelines  sales_pipelines?   @relation(fields: [pipeline_id], references: [id], onUpdate: NoAction)
  sales_stages     sales_stages?      @relation(fields: [stage_id], references: [id], onUpdate: NoAction)

  @@index([client_id], map: "idx_sales_deals_client")
  @@index([pipeline_id], map: "idx_sales_deals_pipeline")
  @@index([stage_id], map: "idx_sales_deals_stage")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model sales_pipelines {
  id           String         @id
  name         String
  createdat    DateTime?      @default(now()) @db.Timestamptz(6)
  updatedat    DateTime?      @default(now()) @db.Timestamptz(6)
  createdAt    DateTime?      @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime?      @default(now()) @db.Timestamptz(6)
  sales_deals  sales_deals[]
  sales_stages sales_stages[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model sales_stages {
  id              String           @id
  pipeline_id     String?
  name            String
  order_index     Int              @default(0)
  probability     Int              @default(0)
  createdat       DateTime?        @default(now()) @db.Timestamptz(6)
  updatedat       DateTime?        @default(now()) @db.Timestamptz(6)
  createdAt       DateTime?        @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime?        @default(now()) @db.Timestamptz(6)
  sales_deals     sales_deals[]
  sales_pipelines sales_pipelines? @relation(fields: [pipeline_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model saved_views {
  id        String    @id
  userid    String
  pagekey   String
  name      String
  filters   Json
  createdat DateTime? @default(now()) @db.Timestamptz(6)
  updatedat DateTime? @default(now()) @db.Timestamptz(6)
  users     users     @relation(fields: [userid], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userid, pagekey], map: "saved_views_user_page_idx")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model spi_cpi_daily_snapshot {
  id        String    @id
  projectid String
  date      DateTime  @db.Date
  spi       Decimal   @db.Decimal
  cpi       Decimal   @db.Decimal
  createdat DateTime? @default(now()) @db.Timestamptz(6)
  projects  projects  @relation(fields: [projectid], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([projectid, date], map: "spi_cpi_daily_snapshot_unique")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model stakeholders {
  id           String   @id
  name         String
  role         String?
  organization String?
  email        String?
  phone        String?
  created_at   DateTime @default(now()) @db.Timestamp(6)
  updated_at   DateTime @db.Timestamp(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model system_settings {
  key         String   @id
  value       String
  description String?
  updated_at  DateTime @default(now()) @db.Timestamp(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model resource_allocations {
  id            String   @id @default(cuid())
  userId        String
  projectId     String
  hoursPerWeek  Decimal  @db.Decimal(5, 2)
  startDate     DateTime @db.Date
  endDate       DateTime @db.Date
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user      users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   projects @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId, startDate])
  @@map("resource_allocations")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model task_actual_logs {
  id               String   @id
  task_id          String
  date             DateTime @db.Date
  progress_percent Decimal  @default(0) @db.Decimal
  tasks            tasks    @relation(fields: [task_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([task_id, date], map: "idx_task_actual_logs_task_date")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model task_plan_points {
  id           String   @id
  task_id      String
  date         DateTime @db.Date
  plan_percent Decimal  @default(0) @db.Decimal
  tasks        tasks    @relation(fields: [task_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([task_id, date], map: "idx_task_plan_points_task_date")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tasks {
  id                            String             @id
  title                         String
  description                   String?
  status                        Status             @default(todo)
  priority                      Priority           @default(medium)
  dueDate                       DateTime?
  estimatedHours                Decimal?           @db.Decimal(6, 2)
  actualHours                   Decimal            @default(0.00) @db.Decimal(6, 2)
  weight                        Decimal            @default(1.00) @db.Decimal(10, 2)
  completedAt                   DateTime?
  projectId                     String
  milestoneId                    String?
  assignedTo                    String?
  createdBy                     String
  parentTaskId                  String?
  category                      String?
  storyPoints                   Int?
  sprintId                      String?
  blockedBy                     String?
  blockedReason                 String?
  createdAt                     DateTime           @default(now())
  updatedAt                     DateTime
  comments                      comments[]
  documents                     documents[]
  expenses                      expenses[]
  task_actual_logs              task_actual_logs[]
  task_plan_points              task_plan_points[]
  users_tasks_assignedToTousers users?             @relation("tasks_assignedToTousers", fields: [assignedTo], references: [id])
  users_tasks_createdByTousers  users              @relation("tasks_createdByTousers", fields: [createdBy], references: [id], onDelete: Cascade)
  tasks                         tasks?             @relation("tasksTotasks", fields: [parentTaskId], references: [id])
  other_tasks                   tasks[]            @relation("tasksTotasks")
  projects                      projects           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestones                    milestones?         @relation(fields: [milestoneId], references: [id])
  time_entries                  time_entries[]
  timesheets                    timesheets[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model time_entries {
  id                                   String    @id
  date                                 DateTime
  workType                             WorkType
  projectId                            String?
  taskId                               String?
  userId                               String
  startTime                            String
  endTime                              String?
  hours                                Decimal   @db.Decimal(5, 2)
  description                          String?
  status                               Status    @default(pending)
  approvedBy                           String?
  approvedAt                           DateTime?
  createdAt                            DateTime  @default(now())
  updatedAt                            DateTime
  rejectedReason                       String?
  
  // NEW: Parallel Work Fields (Option 3)
  isConcurrent                         Boolean   @default(false)
  concurrentEntryIds                   String[]  @default([])
  concurrentReason                     String?
  breakDuration                        Int       @default(60) // minutes
  chargeable                           Boolean   @default(false)
  chargeAmount                         Decimal?  @db.Decimal(12, 2)
  billableHours                        Decimal?  @db.Decimal(5, 2)
  
  users_time_entries_approvedByTousers users?    @relation("time_entries_approvedByTousers", fields: [approvedBy], references: [id])
  projects                             projects? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks                                tasks?    @relation(fields: [taskId], references: [id])
  users_time_entries_userIdTousers     users     @relation("time_entries_userIdTousers", fields: [userId], references: [id], onDelete: Cascade)
  time_entry_comments                  time_entry_comments[]

  @@index([status, date], map: "idx_time_entries_status_date")
  @@index([userId, date, status], map: "idx_time_entries_user_date_status")
  @@index([isConcurrent], map: "idx_time_entries_concurrent")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model timesheet_submissions {
  id                String    @id
  user_id           String
  period_start_date DateTime  @db.Date
  period_end_date   DateTime? @db.Date
  total_hours       Decimal?  @default(0) @db.Decimal
  status            String?   @default("Draft")
  submitted_at      DateTime? @db.Timestamp(6)

  @@unique([user_id, period_start_date], map: "idx_timesheet_submissions_user_period")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model timesheets {
  id              String    @id
  user_id         String
  project_id      String
  task_id         String?
  date            DateTime  @db.Date
  hours           Decimal?  @default(0) @db.Decimal
  start_time      DateTime? @db.Timestamp(6)
  end_time        DateTime? @db.Timestamp(6)
  status          String    @default("pending")
  description     String?
  rejected_reason String?
  approved_by     String?
  approved_at     DateTime? @db.Timestamp(6)
  billable        Boolean?  @default(true)
  projects        projects  @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tasks           tasks?    @relation(fields: [task_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users           users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model users {
  id                                          String             @id
  objectId                                    String?            @unique
  name                                        String
  email                                       String             @unique(map: "idx_users_email")
  password                                    String?
  role                                        user_role          @default(employee)
  avatar                                      String?
  department                                  String?
  position                                    String?
  employeeCode                                String?
  hourlyRate                                  Decimal            @default(0.00) @db.Decimal(10, 2)
  phone                                       String?
  status                                      String             @default("active")
  isActive                                    Boolean            @default(true)
  isDeleted                                   Boolean            @default(false)
  failedLoginAttempts                         Int                @default(0)
  lastLogin                                   DateTime?
  lockedUntil                                 DateTime?
  resetToken                                  String?
  resetTokenExpiry                            DateTime?
  isProjectManager                            Boolean            @default(false)
  isSupervisor                                Boolean            @default(false)
  notificationPreferences                     Json?
  timezone                                    String             @default("Asia/Bangkok")
  createdAt                                   DateTime           @default(now())
  updatedAt                                   DateTime
  name_th                                     String?
  weeklyCapacity                              Decimal?           @default(40.00) @db.Decimal(5, 2)
  allocations                                 resource_allocations[]
  activity_log                                activity_log[]
  audit_logs                                  audit_logs[]
  budget_revisions                            budget_revisions[]
  comments                                    comments[]
  documents                                   documents[]
  expenses_expenses_approvedByTousers         expenses[]         @relation("expenses_approvedByTousers")
  expenses_expenses_approverIdTousers         expenses[]         @relation("expenses_approverIdTousers")
  expenses_expenses_userIdTousers             expenses[]         @relation("expenses_userIdTousers")
  project_members                             project_members[]
  projectassignee                             projectassignee[]
  projects                                    projects[]
  risks                                       risks[]
  sales_activities                            sales_activities[]
  sales_deals                                 sales_deals[]
  saved_views                                 saved_views[]
  tasks_tasks_assignedToTousers               tasks[]            @relation("tasks_assignedToTousers")
  tasks_tasks_createdByTousers                tasks[]            @relation("tasks_createdByTousers")
  time_entries_time_entries_approvedByTousers time_entries[]     @relation("time_entries_approvedByTousers")
  time_entries_time_entries_userIdTousers     time_entries[]     @relation("time_entries_userIdTousers")
  timesheets                                  timesheets[]
  leave_allocations                           leave_allocations[]
  leave_requests_user                         leave_requests[]
  leave_requests_approver                     leave_requests[]   @relation("leave_request_approver")
  time_entry_comments                         time_entry_comments[]
  vendorKpiEvaluations                        vendor_kpi_evaluations[]
  }

// ============================================================
// USER RELATED ENUMS
// ============================================================

/// User roles for access control
enum user_role {
  admin
  manager
  employee
}

/// User account status
enum user_status {
  active
  inactive
}

// ============================================================
// PROJECT RELATED ENUMS
// ============================================================

/// Project status lifecycle
enum ProjectStatus {
  planning
  active
  onHold      // kept for backward compatibility with existing database
  completed
  cancelled
}

/// Project priority levels
enum ProjectPriority {
  low
  medium
  high
  urgent
}

/// Project risk levels
enum RiskLevel {
  low
  medium
  high
  critical
}

// ============================================================
// TASK RELATED ENUMS
// ============================================================

/// Task status workflow
enum TaskStatus {
  todo
  in_progress
  in_review
  done
  cancelled
  inactive     // kept for backward compatibility with existing database
}

/// Task priority levels
enum TaskPriority {
  low
  medium
  high
  urgent
}

/// Task categories for classification
enum TaskCategory {
  development
  design
  testing
  documentation
  maintenance
  other
}

// ============================================================
// TIMESHEET & TIME ENTRY ENUMS
// ============================================================

/// Work type for time entries
enum WorkType {
