enum ActivityType {
  create
  update
  delete
  comment
  assign
  status_change
}

enum ExpenseCategory {
  travel
  supplies
  equipment
  training
  other
}

enum ExpenseStatus {
  pending
  approved
  rejected
  reimbursed
}

enum Priority {
  low
  medium
  high
  urgent
}

enum ProjectStatus {
  planning
  active
  onHold
  completed
  cancelled
}

enum Status {
  todo
  in_progress
  in_review
  done
  pending
  approved
  rejected
  active
  inactive
}

enum TaskStatus {
  todo
  in_progress
  in_review
  done
  cancelled
  inactive
}

enum TimeEntryStatus {
  pending
  approved
  rejected
}

enum UserRole {
  admin
  manager
  employee
}

enum WorkType {
  project      // billable project work
  office       // office/admin work
  training     // professional development
  leave        // approved leave
  overtime     // overtime work
  other        // other work
}

enum LeaveType {
  annual
  sick
  personal
  maternity
  unpaid
}

enum user_role {
  admin
  manager
  employee
}

enum user_status {
  active
  inactive
}

/// Leave allocation model for tracking annual leave hours
model leave_allocations {
  id                String   @id @default(cuid())
  user_id           String
  year              Int
  annual_leave_hours Decimal @db.Decimal(8, 2)
  used_leave_hours   Decimal @db.Decimal(8, 2) @default(0)
  remaining_hours    Decimal @db.Decimal(8, 2)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  users              users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  leave_requests     leave_requests[]

  @@unique([user_id, year])
  @@index([user_id])
  @@map("leave_allocations")
}

/// Leave request model for tracking leave requests
model leave_requests {
  id                    String    @id @default(cuid())
  leave_allocation_id   String
  user_id               String
  start_date            DateTime
  end_date              DateTime
  leave_type            LeaveType
  reason                String
  status                Status    @default(pending)
  approved_by           String?
  approved_at           DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  leave_allocations     leave_allocations @relation(fields: [leave_allocation_id], references: [id], onDelete: Cascade)
  users                 users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  approver              users?   @relation("leave_request_approver", fields: [approved_by], references: [id])

  @@index([leave_allocation_id])
  @@index([user_id])
  @@index([status])
  @@map("leave_requests")
}

/// Time entry comment model for tracking comments on time entries
model time_entry_comments {
  id              String   @id @default(cuid())
  time_entry_id   String
  user_id         String
  text            String
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  time_entries    time_entries @relation(fields: [time_entry_id], references: [id], onDelete: Cascade)
  users           users        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([time_entry_id])
  @@map("time_entry_comments")
}
