// TIMESHEET MODELS
// ============================================================================

model timesheet_config {
  id                    String    @id @default(cuid())
  departmentId          String?
  
  standardWeeklyHours   Decimal   @default(40.0) @db.Decimal(5, 2)
  dailyWorkHours        Decimal   @default(8.0) @db.Decimal(5, 2)
  dayStartTime          String    @default("08:00")
  dayEndTime            String    @default("17:00")
  lunchBreakMinutes     Int       @default(60)
  
  allowConcurrentEntries Boolean  @default(false)
  maxConcurrentEntries  Int       @default(2)
  minimumEntryMinutes   Int       @default(15)
  roundingMode          String    @default("nearest_15")
  
  requireDailyApproval  Boolean   @default(false)
  requireWeeklyApproval Boolean   @default(true)
  approvalDueDay        String    @default("friday")
  lockPeriodDays        Int       @default(30)
  
  annualLeaveDays       Int       @default(20)
  sickLeaveDays         Int       @default(10)
  personalLeaveDays     Int       @default(3)
  
  isActive              Boolean   @default(true)
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model time_entries {
  id                    String          @id @default(cuid())
  
  userId                String
  date                  DateTime        @db.Date
  
  entryType             TimesheetEntryType
  
  projectId             String?
  taskId                String?
  wbsTaskId             String?
  
  nonProjectActivityId  String?
  
  leaveRequestId        String?
  leaveType             LeaveType?
  
  startTime             String
  endTime               String?
  breakMinutes          Int             @default(0)
  totalMinutes          Int
  hours                 Decimal         @db.Decimal(5, 2)
  
  description           String?
  
  billable              Boolean         @default(true)
  chargeable            Boolean         @default(false)
  chargeAmount          Decimal?        @db.Decimal(12, 2)
  
  isConcurrentEntry     Boolean         @default(false)
  concurrentReason      String?
  
  status                TimesheetStatus @default(draft)
  approvalStatus        TimeApprovalStatus @default(pending)
  
  submittedAt           DateTime?
  submittedBy           String?
  approvedBy            String?
  approvedAt            DateTime?
  rejectedReason        String?
  
  isLocked              Boolean         @default(false)
  lockedAt              DateTime?
  
  user                  users           @relation("time_entries_userIdTousers", fields: [userId], references: [id], onDelete: Cascade)
  project               projects?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task                  tasks?          @relation(fields: [taskId], references: [id], onDelete: SetNull)
  wbsTask               wbs_task?       @relation(fields: [wbsTaskId], references: [id], onDelete: SetNull)
  nonProjectActivity    non_project_activity? @relation(fields: [nonProjectActivityId], references: [id])
  leaveRequest          leave_requests? @relation(fields: [leaveRequestId], references: [id])
  approver              users?          @relation("time_entries_approvedByTousers", fields: [approvedBy], references: [id])
  submitter             users?          @relation("time_entries_submittedByTousers", fields: [submittedBy], references: [id])
  comments              time_entry_comments[]
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  @@index([userId, date])
  @@index([status, approvalStatus])
  @@index([projectId, date])
  @@index([taskId, date])
  @@index([wbsTaskId, date])
  @@index([isConcurrentEntry])
  @@unique([userId, date, projectId, taskId, startTime], map: "idx_time_entry_unique")
}

model time_entry_comments {
  id                String    @id @default(cuid())
  entryId           String
  userId            String
  
  text              String
  
  entry             time_entries @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user              users     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@index([entryId])
  @@index([userId])
}

model non_project_activity_category {
  id                    String    @id @default(cuid())
