  entry                 time_entries @relation(fields: [entryId], references: [id], onDelete: Cascade)
  project               projects? @relation(fields: [projectId], references: [id])
  task                  tasks?    @relation(fields: [taskId], references: [id])
  wbsTask               wbs_task? @relation(fields: [wbsTaskId], references: [id])
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  @@index([projectId])
  @@index([taskId])
  @@index([wbsTaskId])
  @@index([isIncludedInACWP])
}

// ============================================================================
// CUSTOMER & BILLING MODELS
// ============================================================================

model customers {
  id                String       @id @default(cuid())
  
  name              String
  customerType      CustomerType @default(enterprise)
  contactPerson     String?
  email             String
  phone             String?
  address           String?
  city              String?
  country           String?
  taxId             String?
  
  billingAddress    String?
  billingCity       String?
  billingCountry    String?
  billingEmail      String?
  
  defaultPaymentTerms PaymentTerms @default(net30)
  creditLimit       Decimal?     @db.Decimal(15, 2)
  creditUsed        Decimal      @default(0) @db.Decimal(15, 2)
  
  creditRating      String?
  
  notes             String?
  
  projects          projects[]
  contacts          customer_contacts[]
  invoices          invoices[]
  payments          customer_payments[]
  
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  
  @@index([customerType, creditRating])
}

model customer_contacts {
  id                String       @id @default(cuid())
  customerId        String
  name              String
  title             String?
  email             String
  phone             String?
  isPrimary         Boolean      @default(false)
  role              String
  
  customer          customers    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  
  @@index([customerId])
}

model project_billing {
  id                String       @id @default(cuid())
  projectId         String       @unique
  
  billingType       BillingType
  totalBillingAmount Decimal     @db.Decimal(15, 2)
  currency          String       @default("THB")
  
  paymentTerms      PaymentTerms
  invoicingSchedule Json?
  
  discountPercent   Decimal      @default(0) @db.Decimal(5, 2)
  taxType           TaxType      @default(vat)
  taxPercent        Decimal      @default(7) @db.Decimal(5, 2)
  
  notes             String?
  
  project           projects     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  installments      billing_installment[]
  
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model billing_installment {
  id                String       @id @default(cuid())
  billingId         String
  
  installmentNumber Int
  description       String?
  
  scheduledDate     DateTime
  amount            Decimal      @db.Decimal(15, 2)
  
  status            InstallmentStatus @default(scheduled)
  invoicedDate      DateTime?
  paidDate          DateTime?
  
  billing           project_billing @relation(fields: [billingId], references: [id], onDelete: Cascade)
  
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  
  @@index([billingId, status])
}

model invoices {
  id                String       @id @default(cuid())
  customerId        String
  billingId         String?
  projectId         String
  
  invoiceNumber     String       @unique
  invoiceDate       DateTime
  dueDate           DateTime
  
  subtotal          Decimal      @db.Decimal(15, 2)
  discountAmount    Decimal      @default(0) @db.Decimal(15, 2)
  taxAmount         Decimal      @db.Decimal(15, 2)
  totalAmount       Decimal      @db.Decimal(15, 2)
  
  lineItems         Json
  notes             String?
  
  status            InvoiceStatus @default(draft)
  
  paidAmount        Decimal      @default(0) @db.Decimal(15, 2)
  remainingAmount   Decimal      @db.Decimal(15, 2)
  paidDate          DateTime?
  
  paymentLink       String?
  paymentMethod     String?
  
  sentDate          DateTime?
  viewedDate        DateTime?
  approvedDate      DateTime?
  
  customer          customers    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  billing           project_billing? @relation(fields: [billingId], references: [id])
  project           projects     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  payments          customer_payments[]
  
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  
  @@index([customerId, status])
  @@index([projectId])
  @@index([dueDate])
}

model customer_payments {
  id                String       @id @default(cuid())
  customerId        String
  invoiceId         String?
  projectId         String
  
  paymentDate       DateTime
  amount            Decimal      @db.Decimal(15, 2)
  
  referenceNumber   String?
  paymentMethod     String
  transactionId     String?
  
  status            String       @default("recorded")
  
  notes             String?
  
  customer          customers    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  invoice           invoices?    @relation(fields: [invoiceId], references: [id])
  project           projects     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  
  @@index([customerId, paymentDate])
  @@index([invoiceId])
}

model project_financials {
  id                String       @id @default(cuid())
  projectId         String       @unique
  
  totalBillingAmount Decimal     @db.Decimal(15, 2)
  totalInvoiced     Decimal      @default(0) @db.Decimal(15, 2)
  totalCollected    Decimal      @default(0) @db.Decimal(15, 2)
  pendingCollection Decimal      @db.Decimal(15, 2)
  
  totalCost         Decimal      @default(0) @db.Decimal(15, 2)
  laborCost         Decimal      @default(0) @db.Decimal(15, 2)
  materialCost      Decimal      @default(0) @db.Decimal(15, 2)
  equipmentCost     Decimal      @default(0) @db.Decimal(15, 2)
  overheadCost      Decimal      @default(0) @db.Decimal(15, 2)
  otherCost         Decimal      @default(0) @db.Decimal(15, 2)
  
  grossProfit       Decimal      @db.Decimal(15, 2)
  marginPercent     Decimal      @db.Decimal(5, 2)
  netProfit         Decimal      @db.Decimal(15, 2)
  roi               Decimal      @db.Decimal(5, 2)
  
  budgetVariance    Decimal      @db.Decimal(15, 2)
  budgetVariancePercent Decimal  @db.Decimal(5, 2)
  
  daysOverdue       Int          @default(0)
  collectionRate    Decimal      @db.Decimal(5, 2)
  averagePaymentDays Int?
  
  lastUpdated       DateTime     @default(now())
  
  project           projects     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

// ============================================================================
// VENDOR & PROCUREMENT MODELS
// ============================================================================

model vendors {
  id                String       @id @default(cuid())
  
  code              String       @unique
  name              String
  vendorType        VendorType   @default(supplier)
  category          String?
  email             String
  phone             String
  address           String
  city              String
  country           String
  
  taxId             String?
  licenseNumber     String?
  
  primaryContact    String?
  accountManager    String?
  status            String       @default("active")
  
  bankAccount       String?
  bankName          String?
  paymentTerms      PaymentTerms @default(net30)
  creditLimit       Decimal?     @db.Decimal(12, 2)
  
  overallRating     VendorRating @default(satisfactory)
  totalProjects     Int          @default(0)
  successfulProjects Int         @default(0)
  averageDeliveryTime Int?
  onTimeDeliveryRate Decimal?    @db.Decimal(5, 2)
  
  totalSpent        Decimal      @default(0) @db.Decimal(15, 2)
  averageOrderValue Decimal?     @db.Decimal(12, 2)
  
  notes             String?
  
  contracts         vendor_contracts[]
  payments          vendor_payments[]
  invoices          vendor_invoices[]
  kpiEvaluations    vendor_kpi_evaluations[]
  expenseItems      expense_items[]
  
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  
  @@index([vendorType, status])
  @@index([overallRating])
}

model vendor_contracts {
  id                String       @id @default(cuid())
  vendorId          String
  projectId         String?
  
  contractNumber    String       @unique
  title             String
  description       String?
  contractType      ContractType
  
  startDate         DateTime
  endDate           DateTime?
  autoRenewal       Boolean      @default(false)
  
  value             Decimal      @db.Decimal(15, 2)
  currency          String       @default("THB")
  paymentTerms      String?
  paymentSchedule   Json?
  
  status            ContractStatus @default(draft)
  
  signingDate       DateTime?
  expiryDate        DateTime?
  autoRenewalDate   DateTime?
  
  notes             String?
  
  vendor            vendors      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  project           projects?    @relation(fields: [projectId], references: [id])
  payments          vendor_payments[]
  
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  
  @@index([vendorId, status])
  @@index([projectId])
}

model vendor_payments {
  id                String           @id @default(cuid())
  vendorId          String
  contractId        String?
  projectId         String?
  
  paymentType       VendorPaymentType
  amount            Decimal          @db.Decimal(12, 2)
  currency          String           @default("THB")
  dueDate           DateTime
  paidDate          DateTime?
  
  installmentNumber Int?
  totalInstallments Int?
  
  status            PaymentStatus    @default(pending)
  paymentMethod     PaymentMethod?
  transactionId      String?
  receiptUrl        String?
  
  approvedBy        String?
  approvedAt        DateTime?
  rejectedReason    String?
  
  description       String?
  notes             String?
  
  vendor            vendors          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  contract          vendor_contracts? @relation(fields: [contractId], references: [id])
  project           projects?        @relation(fields: [projectId], references: [id])
  
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  
  @@index([vendorId, status])
  @@index([dueDate, status])
  @@index([projectId])
}

model vendor_invoices {
  id                String       @id @default(cuid())
  vendorId          String
  projectId         String?
  contractId        String?
  
  invoiceNumber     String       @unique
  invoiceDate       DateTime
  dueDate           DateTime
  
  amount            Decimal      @db.Decimal(15, 2)
  currency          String       @default("THB")
  
  status            InvoiceStatus @default(draft)
  
  paidDate          DateTime?
  paidAmount        Decimal      @default(0) @db.Decimal(15, 2)
  
  notes             String?
  
  vendor            vendors      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  project           projects?    @relation(fields: [projectId], references: [id])
  
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  
  @@index([vendorId, status])
  @@index([invoiceNumber])
}

model purchase_orders {
  id                String       @id @default(cuid())
  projectId         String
  vendorId          String
  
  poNumber          String       @unique
  description       String
  
  amount            Decimal      @db.Decimal(15, 2)
  
  status            String       @default("draft")
  
  issuedDate        DateTime?
  expectedDelivery  DateTime?
  actualDelivery    DateTime?
  
  notes             String?
  
  project           projects     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  
  @@index([projectId, status])
}

model expense_items {
  id              String           @id @default(cuid())
  expenseId       String
  vendorId        String?
  
  category        ExpenseCategory
  subcategory     String?
  description     String
  quantity        Decimal          @default(1) @db.Decimal(10, 2)
  unitPrice       Decimal          @db.Decimal(12, 2)
  totalPrice      Decimal          @db.Decimal(12, 2)
  
  baseCost        Decimal          @db.Decimal(12, 2)
  markup          Decimal          @default(0) @db.Decimal(5, 2)
  marginAmount    Decimal          @db.Decimal(12, 2)
  finalPrice      Decimal          @db.Decimal(12, 2)
  
  vendorItemCode  String?
  vendorInvoice   String?
  
  notes           String?
  
  expense         expenses         @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  vendor          vendors?         @relation(fields: [vendorId], references: [id])
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  @@index([expenseId])
  @@index([vendorId])
  @@index([category])
}

model vendor_kpi_evaluations {
  id              String    @id @default(cuid())
  vendorId        String
  projectId       String?
  evaluationPeriod String
  
  qualityScore    Decimal   @db.Decimal(3, 1)
  timelinessScore Decimal   @db.Decimal(3, 1)
  costScore       Decimal   @db.Decimal(3, 1)
  communicationScore Decimal @db.Decimal(3, 1)
  technicalScore  Decimal   @db.Decimal(3, 1)
  
  overallScore    Decimal   @db.Decimal(3, 1)
  rating          VendorRating
  
  evaluatorId     String
  strengths       String?
  weaknesses      String?
  recommendations String?
  nextEvaluationDate DateTime?
  
  notes           String?
  
  vendor          vendors   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  project         projects? @relation(fields: [projectId], references: [id])
  evaluator       users     @relation("EvaluatorId", fields: [evaluatorId], references: [id])
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([vendorId, evaluationPeriod])
  @@index([projectId])
  @@index([overallScore])
}

model vendor_kpi_criteria {
  id              String    @id @default(cuid())
  name            String
  category        KpiCategory
  description     String
  weight          Decimal   @db.Decimal(3, 1) @default(1.0)
  measurementUnit String?
  targetValue     Decimal?  @db.Decimal(10, 2)
  minValue        Decimal?  @db.Decimal(10, 2)
  maxValue        Decimal?  @db.Decimal(10, 2)
  
  isActive        Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([category])
  @@index([isActive])
}

// ============================================================================
// SALES & DEALS (Existing Models - Retained)
// ============================================================================

model sales_deals {
  id            String   @id
  project_id    String
  contact_id    String
  deal_value    Decimal? @db.Decimal
  deal_status   String
  expected_close DateTime?
  created_at    DateTime @default(now())
  projects      projects @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  contacts      contacts @relation(fields: [contact_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users         users    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user_id       String

  @@index([project_id], map: "idx_sales_deals_project")
  @@index([contact_id], map: "idx_sales_deals_contact")
}
