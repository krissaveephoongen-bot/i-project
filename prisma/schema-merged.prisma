  categoryId            String
  
  name                  String
  description           String?
  
  allocatedFor          String?
  
  startDate             DateTime  @db.Date
  endDate               DateTime  @db.Date
  isRecurring           Boolean   @default(false)
  recurringPattern      String?
  
  isActive              Boolean   @default(true)
  
  category              non_project_activity_category @relation(fields: [categoryId], references: [id])
