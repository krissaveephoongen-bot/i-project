  weekEndDate           DateTime  @db.Date
  
  submittedAt           DateTime
  submittedBy           String
  approvedAt            DateTime?
  approvedBy            String?
  approverComments      String?
  
  user                  users     @relation(fields: [userId], references: [id], onDelete: Cascade)
  submitter             users?    @relation("SubmittedBy", fields: [submittedBy], references: [id])
  approver              users?    @relation("ApprovedBy", fields: [approvedBy], references: [id])
  
  createdAt             DateTime  @default(now())
  
  @@index([userId])
  @@index([submittedAt])
}

model leave_allocations {
