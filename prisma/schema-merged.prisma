// ============================================================================
// SCHEDULE & PENALTY MODELS
// ============================================================================

model project_schedule {
  id                    String          @id @default(cuid())
  projectId             String          @unique
  
  contractStartDate     DateTime
  contractEndDate       DateTime
  totalContractDays     Int
  
  actualStartDate       DateTime?
  currentProgress       Decimal         @default(0) @db.Decimal(5, 2)
  forecastEndDate       DateTime?
  
  status                ScheduleHealth  @default(on_track)
  daysAhead             Int             @default(0)
  daysBehind            Int             @default(0)
  remainingDays         Int
  
  criticalMilestones    Int             @default(0)
  missedMilestones      Int             @default(0)
  
  scheduledProgress     Decimal         @db.Decimal(5, 2)
  scheduleVariancePercent Decimal       @db.Decimal(5, 2)
  
  riskOfMissingDeadline Decimal         @db.Decimal(5, 2)
  
  project               projects        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestones            schedule_milestone[]
  extensions            schedule_extension[]
  penalties             contract_penalty[]
  progressHistory       schedule_progress_history[]
  
  lastCalculated        DateTime        @default(now())
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  @@index([projectId, status])
}

model schedule_milestone {
  id                    String          @id @default(cuid())
  scheduleId            String
  
  code                  String
  name                  String
  description           String?
  sequenceNumber        Int
  
  contractualDate       DateTime
  plannedDate           DateTime?
  actualDate            DateTime?
  
  status                String          @default("pending")
  isCritical            Boolean         @default(false)
  
  deliverables          String?
  completionCriteria    String?
  
  penaltyIfMissed       Decimal?        @db.Decimal(15, 2)
  
  schedule              project_schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  @@unique([scheduleId, code])
  @@index([scheduleId, status])
}

model schedule_progress_history {
  id                    String          @id @default(cuid())
  scheduleId            String
  
  dataDate              DateTime
  dayNumber             Int
  
  actualProgress        Decimal         @db.Decimal(5, 2)
  expectedProgress      Decimal         @db.Decimal(5, 2)
  
  scheduleVariance      Decimal         @db.Decimal(5, 2)
  variancePercentage    Decimal         @db.Decimal(5, 2)
  
  accumulativeVariance  Decimal         @db.Decimal(5, 2)
  velocityTrend         String?
  
  health                ScheduleHealth
  
  forecastEndDate       DateTime?
  forecatedDaysLate     Int?
  
  schedule              project_schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  
  createdAt             DateTime        @default(now())
  
  @@unique([scheduleId, dataDate])
  @@index([scheduleId, dataDate])
}

model schedule_extension {
  id                    String          @id @default(cuid())
  scheduleId            String
  
  extensionNumber       Int
  requestedDays         Int
  approvedDays          Int?
  
  originalEndDate       DateTime
  newEndDate            DateTime?
  requestDate           DateTime
  approvalDate          DateTime?
  
  reason                String
  
  status                ExtensionStatus @default(requested)
  
  pendingPenalties      Decimal         @default(0) @db.Decimal(15, 2)
  
  requestedBy           String
  approvedBy            String?
  rejectionReason       String?
  
  notes                 String?
  
  schedule              project_schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  requester             users           @relation("ExtensionRequestedBy", fields: [requestedBy], references: [id])
  approver              users?          @relation("ExtensionApprovedBy", fields: [approvedBy], references: [id])
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  @@index([scheduleId, status])
}

model contract_penalty_structure {
  id                    String          @id @default(cuid())
  projectId             String?         @unique
  
  penaltyType           PenaltyType     @default(daily_rate)
  totalContractValue    Decimal         @db.Decimal(15, 2)
  
  dailyPenaltyAmount    Decimal?        @db.Decimal(12, 2)
  dailyPenaltyPercent   Decimal?        @db.Decimal(5, 2)
  tieredPenalties       Json?
  milestoneStructure    Json?
  
  maxPenaltyPercent     Decimal         @default(10.0) @db.Decimal(5, 2)
  maxPenaltyAmount      Decimal?        @db.Decimal(15, 2)
  
  gracePeriodDays       Int             @default(0)
  
  status                String          @default("active")
  
  project               projects?       @relation(fields: [projectId], references: [id])
  penalties             contract_penalty[]
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
}

model contract_penalty {
  id                    String          @id @default(cuid())
  scheduleId            String
  structureId           String
  
  penaltyNumber         String          @unique
  
  startDate             DateTime
  endDate               DateTime?
  
  daysLate              Int
  
  penaltyType           PenaltyType
  penaltyBasis          Decimal         @db.Decimal(15, 2)
  calculationMethod     String
  penaltyAmount         Decimal         @db.Decimal(15, 2)
  
  baseAmount            Decimal         @db.Decimal(15, 2)
  adjustments           Json?
  netPenalty            Decimal         @db.Decimal(15, 2)
  
  status                PenaltyStatus   @default(pending)
  
  approvedBy            String?
  approvedDate          DateTime?
  appliedDate           DateTime?
  
  waivedAmount          Decimal         @default(0) @db.Decimal(15, 2)
  waivedReason          String?
  waivedBy              String?
  waivedDate            DateTime?
  
  disputedBy            String?
  disputeReason         String?
  disputeDate           DateTime?
  disputeResolution     String?
  
  notes                 String?
  
  schedule              project_schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  structure             contract_penalty_structure @relation(fields: [structureId], references: [id])
  approver              users?          @relation("PenaltyApprovedBy", fields: [approvedBy], references: [id])
  disputer              users?          @relation("PenaltyDisputedBy", fields: [disputedBy], references: [id])
  waiver                users?          @relation("PenaltyWaivedBy", fields: [waivedBy], references: [id])
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  @@index([scheduleId, status])
  @@index([penaltyNumber])
}

model schedule_compliance {
  id                    String          @id @default(cuid())
  projectId             String          @unique
  
  contractStartDate     DateTime
  contractEndDate       DateTime
  totalContractDays     Int
  
  currentDay            Int
  currentProgress       Decimal         @db.Decimal(5, 2)
  expectedProgress      Decimal         @db.Decimal(5, 2)
  progressVariance      Decimal         @db.Decimal(5, 2)
  
  schedulePerformanceIndex Decimal      @db.Decimal(5, 3)
  
  totalMilestones       Int
  completedMilestones   Int
  missedMilestones      Int
  milestoneCompletionRate Decimal       @db.Decimal(5, 2)
  
  overallHealth         ScheduleHealth
  daysAhead             Int             @default(0)
  daysBehind            Int             @default(0)
  remainingDays         Int
  
  forecastEndDate       DateTime?
  forecastedDaysLate    Int?
  probability           Decimal         @db.Decimal(5, 2)
  
  totalPenalties        Decimal         @default(0) @db.Decimal(15, 2)
  pendingPenalties      Decimal         @default(0) @db.Decimal(15, 2)
  appliedPenalties      Decimal         @default(0) @db.Decimal(15, 2)
  waivedPenalties       Decimal         @default(0) @db.Decimal(15, 2)
  
  riskOfMissDeadline    Decimal         @db.Decimal(5, 2)
  recommendedAction     String?
  
  lastUpdated           DateTime        @default(now())
  
  project               projects        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
}

model schedule_recovery_plan {
  id                    String          @id @default(cuid())
  projectId             String
  
  planNumber            String          @unique
  
  triggerDate           DateTime
  daysBehind            Int
  
  requiredDaysToRecover Int
  daysAvailable         Int
  
  actions               Json
  
  recoveryDays          Int
  additionalCost        Decimal         @db.Decimal(15, 2)
  riskLevel             String
  successProbability    Decimal         @db.Decimal(5, 2)
  
  status                String          @default("draft")
  approvedBy            String?
