// ============================================================================
// COMPREHENSIVE PROJECT MANAGEMENT SCHEMA - MERGED VERSION
// WBS, EVM, Schedule, Penalty, Timesheet, Vendor, Customer, Billing
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS - All Core Data Types
// ============================================================================

enum ActivityType {
  create
  update
  delete
  status_change
  comment
  attachment
}

enum Status {
  todo
  in_progress
  in_review
  done
  cancelled
  on_hold
}

enum Priority {
  low
  medium
  high
  urgent
}

enum ExpenseCategory {
  equipment
  software
  consulting
  travel
  other
}

enum ExpenseStatus {
  pending
  approved
  rejected
  paid
}

enum WBSLevel {
  project
  phase
  workpackage
  task
  subtask
}

enum ProgressMethod {
  duration_based
  resource_based
  deliverable_based
}

enum CostCategory {
  labor
  material
  equipment
  overhead
  contingency
  expense
}

enum PeriodType {
  daily
  weekly
  monthly
  quarterly
}

enum RiskLevel {
  low
  medium
  high
  critical
}

enum PenaltyType {
  daily_rate
  percentage_contract
  cumulative
  milestone_based
  tiered
}

enum PenaltyStatus {
  pending
  calculated
  disputed
  approved
  collected
  waived
}

enum ExtensionStatus {
  requested
  under_review
  approved
  rejected
  accepted
}

enum ScheduleHealth {
  on_track
  at_risk
  critical
  off_track
}

enum InvoiceStatus {
  draft
  sent
  viewed
  partial_paid
  paid
  overdue
  cancelled
}

enum BillingType {
  fixed_price
  time_and_material
  milestone_based
  installment
  hybrid
}

enum PaymentTerms {
  immediate
  net15
  net30
  net45
  net60
  custom
}

enum InstallmentStatus {
  scheduled
  invoiced
  partial_paid
  fully_paid
  overdue
  cancelled
}

enum TaxType {
  vat
  gst
  sales_tax
  none
}

enum CustomerType {
  enterprise
  smb
  startup
  government
  non_profit
}

enum VendorType {
  supplier
  contractor
  equipment
  outsourcer
  consultant
}

enum VendorRating {
  poor
  satisfactory
  good
  excellent
}

enum KpiCategory {
  quality
  timeliness
  cost
  communication
  technical
}

enum ContractType {
  framework
  project
  supply
  service
  maintenance
}

enum ContractStatus {
  draft
  negotiation
  signed
  active
  completed
  terminated
}

enum VendorPaymentType {
  advance
  milestone
  installment
  final
  retainage
}

enum PaymentStatus {
  pending
  partial
  completed
  overdue
  cancelled
}

enum PaymentMethod {
  bank_transfer
  cash
  cheque
  credit_card
  online
}

enum TimesheetEntryType {
  project_task
  non_project
  leave
}

enum LeaveType {
  vacation
  sick
  personal
  unpaid
  public_holiday
  maternity
  paternity
  study
}

enum TimesheetStatus {
  draft
  submitted
  under_review
  approved
  rejected
  locked
}

enum TimeApprovalStatus {
  pending
  approved
  rejected
  appealed
}

// ============================================================================
// CORE MODELS - Existing Base Models
// ============================================================================

model activity_log {
  id          String       @id
  entityType  String
  entityId    String
  type        ActivityType
  action      String
  description String?
  userId      String
  changes     Json?
  createdAt   DateTime     @default(now())
  users       users        @relation(fields: [userId], references: [id])
}

model audit_logs {
  id         String    @id
  project_id String?
  user_id    String?
  event_type String
  severity   String
  details    String?
  ip_address String?
  user_agent String?
  created_at DateTime  @default(now()) @db.Timestamp(6)
  projects   projects? @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model budget_lines {
  id                   String    @id
  project_id           String
  type                 String
  amount               Decimal   @default(0) @db.Decimal
  date                 DateTime? @db.Date
  related_milestone_id String?
  projects             projects  @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([project_id, date], map: "idx_budget_lines_project_date")
}

model budget_revisions {
  id             String   @id
  projectId      String
  previousBudget Decimal  @db.Decimal(12, 2)
  newBudget      Decimal  @db.Decimal(12, 2)
  reason         String
  changedBy      String
  changedAt      DateTime @default(now())
  users          users    @relation(fields: [changedBy], references: [id])
  projects       projects @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model clients {
  id        String     @id
  name      String
  email     String?
  phone     String?
  address   String?
  taxId     String?
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime
  projects  projects[]
}

model comments {
  id        String   @id
  taskId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime
  tasks     tasks    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  users     users    @relation(fields: [userId], references: [id])
}

model contacts {
  id            String        @id
  project_id    String
  name          String?
  position      String?
  email         String?
  phone         String?
  type          String?
  is_key_person Boolean?      @default(false)
  projects      projects      @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sales_deals   sales_deals[]

  @@index([project_id], map: "idx_contacts_project")
  @@index([type], map: "idx_contacts_type")
}

model documents {
  id         String    @id
  name       String
  type       String?
  size       String?
  url        String?
  projectId  String?
  taskId     String?
  uploadedBy String?
  milestone  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime
  projects   projects? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks      tasks?    @relation(fields: [taskId], references: [id])
  users      users?    @relation(fields: [uploadedBy], references: [id])
}

model expenses {
  id                               String          @id
  date                             DateTime
  projectId                        String
  taskId                           String?
  userId                           String
  amount                           Decimal         @db.Decimal(12, 2)
  category                         ExpenseCategory
  description                      String
  receiptUrl                       String?
  status                           ExpenseStatus   @default(pending)
  approvedBy                       String?
  approvedAt                       DateTime?
  notes                            String?
  createdAt                        DateTime        @default(now())
  updatedAt                        DateTime
  rejectedReason                   String?
  details                          Json?
  approver_id                      String?
  approverId                       String?
  users_expenses_approvedByTousers users?          @relation("expenses_approvedByTousers", fields: [approvedBy], references: [id])
  users_expenses_approverIdTousers users?          @relation("expenses_approverIdTousers", fields: [approverId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "expenses_approverid_fkey")
  projects                         projects        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks                            tasks?          @relation(fields: [taskId], references: [id])
  users_expenses_userIdTousers     users           @relation("expenses_userIdTousers", fields: [userId], references: [id], onDelete: Cascade)
  expenseItems                     expense_items[]

  @@index([status, date], map: "idx_expenses_status_date")
}

model financial_data {
  id        String   @id
  month     DateTime @unique
  revenue   Decimal  @default(0.00) @db.Decimal(15, 2)
  cost      Decimal  @default(0.00) @db.Decimal(15, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model milestones {
  id          String    @id
  title       String
  description String?
  dueDate     DateTime
  amount      Decimal?  @db.Decimal(15, 2)
  status      String    @default("pending")
  progress    Int       @default(0)
  projectId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  name        String?
  percentage  Decimal?  @default(0.00) @db.Decimal
  projects    projects? @relation(fields: [projectId], references: [id])
  tasks       tasks[]
}

model project_members {
  id        String   @id
  projectId String
  userId    String
  role      String   @default("member")
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime
  projects  projects @relation(fields: [projectId], references: [id], onDelete: Cascade)
  users     users    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model project_progress_history {
  id        String   @id
  projectId String
  progress  Int
  weekDate  DateTime
  createdAt DateTime @default(now())
  projects  projects @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model project_progress_snapshots {
  id             String   @id
  project_id     String
  date           DateTime @db.Date
  plan_percent   Decimal  @default(0) @db.Decimal
  actual_percent Decimal  @default(0) @db.Decimal
  spi            Decimal? @db.Decimal
  projects       projects @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([project_id, date], map: "idx_project_progress_snapshots_project_date")
}

model projectassignee {
  A        String
  B        String
  projects projects @relation(fields: [A], references: [id], onDelete: Cascade, map: "_ProjectAssignee_A_fkey")
  users    users    @relation(fields: [B], references: [id], onDelete: Cascade, map: "_ProjectAssignee_B_fkey")

  @@id([A, B], map: "_ProjectAssignee_AB_pkey")
  @@index([B], map: "_ProjectAssignee_B_index")
}

// ============================================================================
// USERS MODEL - EXTENDED WITH TIMESHEET FIELDS
// ============================================================================

model users {
  id                               String                   @id
  username                         String?                  @unique
  email                            String                   @unique
  password                         String
  name                             String?
  avatar                           String?
  role                             String                   @default("user")
  department                       String?
  position                         String?
  phone                            String?
  
  // Timesheet Fields
  hourlyRate                       Decimal                  @default(0) @db.Decimal(10, 2)
  weeklyCapacity                   Decimal                  @default(40) @db.Decimal(5, 2)
  
  // Metadata
  createdAt                        DateTime                 @default(now())
  updatedAt                        DateTime                 @updatedAt
  
  // Relations
  activity_logs                    activity_log[]
  audit_logs                       audit_logs[]
  budget_revisions                 budget_revisions[]
  comments                         comments[]
  documents                        documents[]
  expenses_approvedBy              expenses[]               @relation("expenses_approvedByTousers")
  expenses_approverId              expenses[]               @relation("expenses_approverIdTousers")
  expenses                         expenses[]               @relation("expenses_userIdTousers")
  projects                         projects[]               @relation("ProjectManager")
  project_members                  project_members[]
  sales_deals                      sales_deals[]
  tasks                            tasks[]                  @relation("TaskAssignee")
  tasks_created                    tasks[]                  @relation("TaskCreator")
  
  // WBS & EVM Relations
  wbsTasks                         wbs_task[]
  evm_snapshots                    evm_period_snapshot[]    @relation("SnapshotCalculatedBy")
  project_baselines                project_baseline[]       @relation("BaselineApprovedBy")
  change_requests                  change_request[]         @relation("ChangeRequestSubmittedBy")
  change_request_approvals         change_request[]         @relation("ChangeRequestApprovedBy")
  project_risks                    project_risk[]           @relation("RiskOwner")
  
  // Schedule & Penalty Relations
  schedule_extensions              schedule_extension[]     @relation("ExtensionRequestedBy")
  schedule_extension_approvals     schedule_extension[]     @relation("ExtensionApprovedBy")
  contract_penalties               contract_penalty[]       @relation("PenaltyApprovedBy")
  penalty_disputes                 contract_penalty[]       @relation("PenaltyDisputedBy")
  penalty_waivers                  contract_penalty[]       @relation("PenaltyWaivedBy")
  
  // Timesheet Relations
  timeEntries                      time_entries[]           @relation("time_entries_userIdTousers")
  timeEntriesAsApprover            time_entries[]           @relation("time_entries_approvedByTousers")
  timeEntriesAsSubmitter           time_entries[]           @relation("time_entries_submittedByTousers")
  timeEntryComments                time_entry_comments[]
  leaveAllocations                 leave_allocations[]
  leaveRequestsUser                leave_requests[]         @relation("leave_request_user")
  leaveRequestsApprover            leave_requests[]         @relation("leave_request_approver")
  dailySummaries                   daily_timesheet_summary[]
  weeklySummaries                  weekly_timesheet_summary[]
  timesheetStats                   timesheet_statistics?
  timesheetSubmissions             timesheet_submission[]
  
  // Vendor & Customer Relations
  vendorEvaluations                vendor_kpi_evaluations[] @relation("EvaluatorId")
  
  @@index([role])
  @@index([department])
}

// ============================================================================
// PROJECTS MODEL - EXTENDED WITH ALL RELATIONS
// ============================================================================

model projects {
  id                         String                       @id
  name                       String
  code                       String?                      @unique
  description                String?
  status                     Status                       @default(todo)
  progress                   Int                          @default(0)
  progressPlan               Int                          @default(0)
  spi                        Decimal                      @default(1.00) @db.Decimal(5, 2)
  riskLevel                  String                       @default("low")
  startDate                  DateTime?
  endDate                    DateTime?
  budget                     Decimal?                     @db.Decimal(12, 2)
  spent                      Decimal                      @default(0.00) @db.Decimal(12, 2)
  remaining                  Decimal                      @default(0.00) @db.Decimal(12, 2)
  managerId                  String?
  clientId                   String?
  hourlyRate                 Decimal                      @default(0.00) @db.Decimal(10, 2)
  
  // EVM Fields (WBS & EVM)
  bac                        Decimal?                     @db.Decimal(15, 2)
  currentBcws                Decimal                      @default(0) @db.Decimal(15, 2)
  currentBcwp                Decimal                      @default(0) @db.Decimal(15, 2)
  currentAcwp                Decimal                      @default(0) @db.Decimal(15, 2)
  currentSpi                 Decimal                      @default(1.00) @db.Decimal(5, 3)
  currentCpi                 Decimal                      @default(1.00) @db.Decimal(5, 3)
  lastEVMCalculation         DateTime?
  
  // Schedule & Timeline Fields
  contractEndDate            DateTime?
  
  // Customer & Billing Fields
  customerId                 String?
  completionDate             DateTime?
  
  // Vendor & Procurement Fields
  
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime                     @updatedAt
  
  // Relations - Existing
  manager                    users?                       @relation("ProjectManager", fields: [managerId], references: [id])
  client                     clients?                     @relation(fields: [clientId], references: [id])
  activities                 activity_log[]
  audit_logs                 audit_logs[]
  budget_lines               budget_lines[]
  budget_revisions           budget_revisions[]
  comments                   comments[]
  contacts                   contacts[]
  documents                  documents[]
  expenses                   expenses[]
  milestones                 milestones[]
  project_members            project_members[]
  project_progress_history   project_progress_history[]
  project_progress_snapshots project_progress_snapshots[]
  assignees                  projectassignee[]
  sales_deals                sales_deals[]
  
  // WBS & EVM Relations
  wbsRoot                    wbs_root?
  baselineSnapshots          project_baseline[]
  changeRequests             change_request[]
  commitments                project_commitment[]
  risks                      project_risk[]
  evmSnapshots               evm_period_snapshot[]
  scurveData                 scurve_data[]
  reportingPeriod            reporting_period?
  
  // Schedule & Penalty Relations
  schedule                   project_schedule?
  penaltyStructure           contract_penalty_structure?
  compliance                 schedule_compliance?
  recoveryPlans              schedule_recovery_plan[]
  
  // Timesheet Relations
  timeEntries                time_entries[]
  timesheetCosts             timesheet_cost[]
  
  // Customer & Billing Relations
  customer                   customers?                   @relation(fields: [customerId], references: [id])
  billing                    project_billing?
  financials                 project_financials?
  invoices                   invoices[]
  customerPayments           customer_payments[]
  
  // Vendor & Procurement Relations
  contracts                  vendor_contracts[]
  purchaseOrders             purchase_orders[]
  vendorInvoices             vendor_invoices[]
  vendorPayments             vendor_payments[]
  vendorEvaluations          vendor_kpi_evaluations[]

  @@index([managerId])
  @@index([clientId])
  @@index([status])
  @@index([customerId])
}

// ============================================================================
// TASKS MODEL - EXTENDED WITH WBS & TIMESHEET
// ============================================================================

model tasks {
  id                String   @id
  projectId         String
  title             String
  description       String?
  status            Status   @default(todo)
  priority          Priority @default(medium)
  progress          Int      @default(0)
  startDate         DateTime?
  dueDate           DateTime?
  assigneeId        String?
  createdBy         String?
  milestoneId       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  project           projects @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee          users?   @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator           users?   @relation("TaskCreator", fields: [createdBy], references: [id])
  milestone         milestones? @relation(fields: [milestoneId], references: [id])
  
  comments          comments[]
  documents         documents[]
  expenses          expenses[]
  
  // WBS & EVM Relations
  taskCosts         task_cost_allocation[]
  taskResources     task_resource_assignment[]
  
  // Timesheet Relations
  timeEntries       time_entries[]
  timesheetCosts    timesheet_cost[]
  
  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
}

// ============================================================================
// WBS & EVM MODELS - Work Breakdown Structure
// ============================================================================

model wbs_root {
  id            String   @id @default(cuid())
  projectId     String   @unique
  baselineDate  DateTime @default(now())
  isBaseline    Boolean  @default(false)
  
  project       projects  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phases        wbs_phase[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([projectId])
}

model wbs_phase {
  id                String   @id @default(cuid())
  wbsRootId         String
  code              String
  name              String
  description       String?
  sequenceNumber    Int
  
  plannedStartDate  DateTime
  plannedEndDate    DateTime
  actualStartDate   DateTime?
  actualEndDate     DateTime?
  
  allocatedBudget   Decimal  @db.Decimal(15, 2)
  budgetPercent     Decimal  @db.Decimal(5, 2)
  
  plannedProgress   Decimal  @default(0) @db.Decimal(5, 2)
  actualProgress    Decimal  @default(0) @db.Decimal(5, 2)
  
  status            String   @default("planned")
  
  wbsRoot           wbs_root    @relation(fields: [wbsRootId], references: [id], onDelete: Cascade)
  workpackages      wbs_workpackage[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@unique([wbsRootId, code])
  @@index([wbsRootId, sequenceNumber])
  @@index([status])
}

model wbs_workpackage {
  id                String   @id @default(cuid())
  phaseId           String
  code              String
  name              String
  description       String?
  sequenceNumber    Int
  
  plannedStartDate  DateTime
  plannedEndDate    DateTime
  actualStartDate   DateTime?
  actualEndDate     DateTime?
  
  allocatedBudget   Decimal  @db.Decimal(15, 2)
  budgetPercent     Decimal  @db.Decimal(5, 2)
  
  plannedProgress   Decimal  @default(0) @db.Decimal(5, 2)
  actualProgress    Decimal  @default(0) @db.Decimal(5, 2)
  progressMethod    ProgressMethod @default(duration_based)
  
  status            String   @default("planned")
  
  phase             wbs_phase        @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  tasks             wbs_task[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@unique([phaseId, code])
  @@index([phaseId, sequenceNumber])
  @@index([status])
}

model wbs_task {
  id                String   @id @default(cuid())
  workpackageId     String
  code              String
  name              String
  description       String?
  sequenceNumber    Int
  
  plannedDuration   Int
  plannedStartDate  DateTime
  plannedEndDate    DateTime
  actualStartDate   DateTime?
  actualEndDate     DateTime?
  
  plannedProgress   Decimal  @default(0) @db.Decimal(5, 2)
  actualProgress    Decimal  @default(0) @db.Decimal(5, 2)
  progressMethod    ProgressMethod @default(resource_based)
  
  allocatedBudget   Decimal  @db.Decimal(15, 2)
  
  assignedUserId    String?
  estimatedHours    Decimal  @db.Decimal(10, 2)
  actualHours       Decimal  @default(0) @db.Decimal(10, 2)
  
  status            String   @default("planned")
  riskLevel         RiskLevel @default(low)
  
  workpackage       wbs_workpackage  @relation(fields: [workpackageId], references: [id], onDelete: Cascade)
  assignedUser      users?           @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  subtasks          wbs_subtask[]
  taskCosts         task_cost_allocation[]
  taskResources     task_resource_assignment[]
  expenses          expenses[]
  timesheets        timesheets[]
  timeEntries       time_entries[]
  timesheetCosts    timesheet_cost[]
  project_commitments project_commitment[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@unique([workpackageId, code])
  @@index([workpackageId, sequenceNumber])
  @@index([assignedUserId])
  @@index([status, riskLevel])
}

model wbs_subtask {
  id                String   @id @default(cuid())
  taskId            String
  code              String
  name              String
  
  plannedDuration   Int
  actualDuration    Int?
  
  actualProgress    Decimal  @default(0) @db.Decimal(5, 2)
  
  estimatedHours    Decimal  @db.Decimal(10, 2)
  actualHours       Decimal  @default(0) @db.Decimal(10, 2)
  allocatedBudget   Decimal  @db.Decimal(15, 2)
  
  status            String   @default("planned")
  
  task              wbs_task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@unique([taskId, code])
  @@index([taskId])
}

model task_cost_allocation {
  id                String   @id @default(cuid())
  taskId            String
  category          CostCategory
  
  description       String?
  plannedAmount     Decimal  @db.Decimal(15, 2)
  actualAmount      Decimal  @default(0) @db.Decimal(15, 2)
  variance          Decimal? @db.Decimal(15, 2)
  
  task              wbs_task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@unique([taskId, category])
  @@index([taskId])
}

model task_resource_assignment {
  id                String   @id @default(cuid())
  taskId            String
  resourceName      String
  resourceType      String
  
  quantity          Decimal  @db.Decimal(10, 2)
  unitCost          Decimal  @db.Decimal(12, 2)
  
  plannedHours      Decimal  @db.Decimal(10, 2)
  actualHours       Decimal  @default(0) @db.Decimal(10, 2)
  
  task              wbs_task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@index([taskId])
}

model evm_period_snapshot {
  id                String   @id @default(cuid())
  projectId         String
  periodStart       DateTime
  periodEnd         DateTime
  
  wbsLevel          WBSLevel
  entityId          String
  
  bac               Decimal? @db.Decimal(15, 2)
  bcws              Decimal  @db.Decimal(15, 2)
  bcwp              Decimal  @db.Decimal(15, 2)
  acwp              Decimal  @db.Decimal(15, 2)
  
  spi               Decimal? @db.Decimal(5, 3)
  cpi               Decimal? @db.Decimal(5, 3)
  
  scheduleVariance  Decimal? @db.Decimal(15, 2)
  costVariance      Decimal? @db.Decimal(15, 2)
  
  eac               Decimal? @db.Decimal(15, 2)
  etcCost           Decimal? @db.Decimal(15, 2)
  vac               Decimal? @db.Decimal(15, 2)
  
  trendStatus       String?
  
  calculatedBy      String?
  project           projects @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user              users?   @relation("SnapshotCalculatedBy", fields: [calculatedBy], references: [id])
  
