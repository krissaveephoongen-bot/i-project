{
  "version": 2,
  "builds": [
    {
      "src": "next-app/package.json",
      "use": "@vercel/next",
      "config": {
        "distDir": ".next"
      }
    },
    {
      "src": "backend/package.json",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/v1/(.*)",
      "dest": "/backend/src/index.ts"
    },
    {
      "src": "/api/(.*)",
      "dest": "/next-app/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/next-app/$1"
    }
  ],
  "crons": [
    {
      "path": "/api/jobs/spi-cpi-snapshot",
      "schedule": "0 0 * * *"
    }
  ]
}
