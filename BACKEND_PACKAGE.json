{
  "name": "ticket-apw-backend",
  "version": "1.0.0",
  "description": "Backend API for Project Management System",
  "private": true,
  "type": "commonjs",
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "build": "npm run prisma:generate",
    "test": "jest",
    "test:auth": "jest tests/integration/auth",
    "test:api": "jest tests/integration/api",
    "db:test": "node scripts/test-connection.js",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "node prisma/seed.js",
    "db:generate": "drizzle-kit generate:pg",
    "db:push": "drizzle-kit push --config ./drizzle.config.ts",
    "db:studio": "prisma studio",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:reset": "prisma migrate reset --force",
    "create:admin": "node scripts/create-admin.js",
    "admin:init": "node scripts/setup-admin-users.js",
    "security:check": "node scripts/secrets-scanner.js",
    "security:verify": "node scripts/security-verify.js",
    "lint": "eslint server --ext .js,.ts",
    "format": "prettier --write \"server/**/*.{js,ts}\""
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^5.22.0",
    "@prisma/engine-core": "^2.0.123",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "date-fns": "^3.3.1",
    "drizzle-orm": "^0.44.7",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.3",
    "lodash.isinteger": "^4.0.4",
    "multer": "^2.0.2",
    "node-fetch": "^2.7.0",
    "pdfkit": "^0.17.2",
    "pg": "^8.16.3",
    "pg-dump": "^0.10.0",
    "postgres": "^3.4.7",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.3.1",
    "redis": "^4.7.1",
    "response-time": "^2.3.4",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.27",
    "@types/pg": "^8.15.6",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.18.1",
    "eslint": "^8.54.0",
    "nodemon": "^3.0.2",
    "prisma": "^5.9.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
