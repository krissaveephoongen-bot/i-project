# ⚠️ SECURITY NOTE: This file is for reference only. Do NOT commit actual secrets.
# REQUIRED: Copy this file to .env and fill in actual values
# ⚠️ WARNING: .env should be in .gitignore and never committed

# Environment Configuration
NODE_ENV=development
APP_ENV=development

# Database (REQUIRED)
DATABASE_URL=postgresql://user:password@localhost:5432/projectdb
DB_HOST=localhost
DB_PORT=5432
DB_NAME=projectdb
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# API Configuration
API_PORT=5000
API_HOST=localhost
API_LOG_LEVEL=info

# Supabase (REQUIRED)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# JWT & Security (REQUIRED)
NEXTAUTH_SECRET=your_nextauth_secret_change_in_production
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRY=7d
SESSION_SECRET=your_session_secret_here

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Third-party Services (if any)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# SENDGRID_API_KEY=SG...

# Feature Flags
ENABLE_ANALYTICS=false
ENABLE_NOTIFICATIONS=true
ENABLE_API_DOCS=true

# CORS
CORS_ORIGIN=http://localhost:5173

# Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_password

# Admin User Setup (REQUIRED for production)
# Format: ADMIN_EMAIL_N, ADMIN_PASSWORD_N, ADMIN_NAME_N where N is a number
# Passwords should be bcrypt hashed
ADMIN_EMAIL_1=admin@example.com
ADMIN_PASSWORD_1=your_bcrypt_hashed_password_here
ADMIN_NAME_1="Admin User"

# Additional admin users (uncomment and update as needed)
# ADMIN_EMAIL_2=admin2@example.com
# ADMIN_PASSWORD_2=your_bcrypt_hashed_password_here
# ADMIN_NAME_2="Another Admin"

# Test User Credentials (for development only)
# These are only used when NODE_ENV is not 'production'
TEST_ADMIN_EMAIL=test-admin@example.com
TEST_ADMIN_PASSWORD=$2a$10$yW.odM7tSqm5R2GrVPxkYuFjAfdswb2BFK5FzYUSnuvaAbjHGZIOO  # Test@1234

TEST_MANAGER_EMAIL=test-manager@example.com
TEST_MANAGER_PASSWORD=$2a$10$yW.odM7tSqm5R2GrVPxkYuFjAfdswb2BFK5FzYUSnuvaAbjHGZIOO

TEST_USER_EMAIL=test-user@example.com
TEST_USER_PASSWORD=$2a$10$yW.odM7tSqm5R2GrVPxkYuFjAfdswb2BFK5FzYUSnuvaAbjHGZIOO

# Test database credentials (for CI/CD pipelines)
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_NAME=test_db
TEST_DB_USER=test_user
TEST_DB_PASSWORD=test_password

# PGAdmin Configuration (for docker-compose)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=your_pgadmin_password

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log
