# Backend Environment Variables (.env)
# Copy this file to .env and update values for your environment
# ⚠️ WARNING: Never commit .env to git
# ⚠️ KEEP ALL SECRETS SECURE

# ===== ENVIRONMENT =====
NODE_ENV=development
PORT=5000
APP_ENV=development

# ===== DATABASE (REQUIRED) =====
# PostgreSQL Connection
DATABASE_URL=postgresql://user:password@localhost:5432/ticket_apw
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ticket_apw
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# ===== JWT & SECURITY (REQUIRED) =====
# Generate strong JWT_SECRET: openssl rand -base64 32
JWT_SECRET=change_me_to_random_32_char_string_in_production
JWT_EXPIRY=7d
REFRESH_TOKEN_SECRET=change_me_to_another_random_string

# Session Configuration
SESSION_SECRET=your_session_secret_here_minimum_32_chars
BCRYPT_ROUNDS=10

# ===== REDIS (Optional - for caching/sessions) =====
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== CORS (REQUIRED) =====
# For local development
CORS_ORIGIN=http://localhost:5173

# For production (update after deploying frontend)
# CORS_ORIGIN=https://ticket-apw.vercel.app

# Multiple origins (if needed)
# CORS_ORIGIN=http://localhost:5173,https://ticket-apw.vercel.app

# ===== API CONFIGURATION =====
API_HOST=localhost
API_LOG_LEVEL=info
API_TIMEOUT=30000

# ===== FILE UPLOAD =====
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads
ALLOWED_FILE_TYPES=pdf,doc,docx,xlsx,xls,txt,jpg,jpeg,png,gif

# ===== SUPABASE (Optional) =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# ===== EMAIL/SMTP (Optional) =====
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=noreply@yourapp.com

# ===== THIRD-PARTY SERVICES (Optional) =====
# Stripe
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# SendGrid
# SENDGRID_API_KEY=SG...

# AWS S3 (if using for file storage)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=

# ===== FEATURE FLAGS =====
ENABLE_ANALYTICS=false
ENABLE_NOTIFICATIONS=true
ENABLE_API_DOCS=true
ENABLE_RATE_LIMITING=true
ENABLE_CACHE=true

# ===== LOGGING =====
LOG_LEVEL=info
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14

# ===== MONITORING (Optional) =====
# Sentry
# SENTRY_DSN=

# New Relic
# NEW_RELIC_LICENSE_KEY=

# ===== ADMIN USER SETUP (REQUIRED for production) =====
# Create initial admin user
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Change@123
ADMIN_NAME="System Administrator"

# Additional admin users (optional)
# ADMIN_EMAIL_2=admin2@example.com
# ADMIN_PASSWORD_2=Change@123
# ADMIN_NAME_2="Secondary Admin"

# ===== TEST CREDENTIALS (Development Only) =====
TEST_ADMIN_EMAIL=test-admin@example.com
TEST_ADMIN_PASSWORD=Test@1234

TEST_MANAGER_EMAIL=test-manager@example.com
TEST_MANAGER_PASSWORD=Test@1234

TEST_USER_EMAIL=test-user@example.com
TEST_USER_PASSWORD=Test@1234

# ===== DATABASE BACKUPS (Optional) =====
# Backup location and schedule
BACKUP_DIR=./backups
BACKUP_SCHEDULE=0 2 * * * # 2 AM daily

# ===== RATE LIMITING =====
RATE_LIMIT_WINDOW=15 # minutes
RATE_LIMIT_MAX_REQUESTS=100 # per window

# ===== PAGINATION =====
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ===== CACHE (if enabled) =====
CACHE_TTL=3600 # seconds (1 hour)
CACHE_PREFIX=ticket_apw_

# ===== SECURITY HEADERS =====
HELMET_ENABLED=true
HELMET_CSP_ENABLED=false # Enable in production

# ===== CORS DETAILED (Alternative to simple CORS_ORIGIN) =====
# Uncomment to use detailed CORS config instead of simple CORS_ORIGIN
# CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
# CORS_ALLOWED_HEADERS=Content-Type,Authorization
# CORS_EXPOSED_HEADERS=X-Total-Count,X-Page-Count
# CORS_CREDENTIALS=true
