#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Pre-commit hook to prevent committing secrets
echo "🔐 Checking for secrets in staged files..."

# Patterns to detect
PATTERNS="password|secret|api[_-]?key|token|credential"

# Get staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|ts|json|env)$')

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# Check each file for suspicious patterns
FOUND_SECRETS=0
for FILE in $STAGED_FILES; do
  # Skip certain directories
  if echo "$FILE" | grep -E "(node_modules|\.next|dist|build)" > /dev/null; then
    continue
  fi
  
  # Check for patterns (case-insensitive)
  if git diff --cached "$FILE" | grep -i -E "$PATTERNS" | grep -v "\.env\.example" > /dev/null; then
    # Additional validation to reduce false positives
    if git diff --cached "$FILE" | grep -i -E "password\s*[:=]|secret\s*[:=]|api[_-]?key\s*[:=]|token\s*[:=]|credential\s*[:=]" > /dev/null; then
      echo "⚠️  Potential secret found in: $FILE"
      FOUND_SECRETS=1
    fi
  fi
done

if [ $FOUND_SECRETS -eq 1 ]; then
  echo ""
  echo "❌ Commit aborted: Potential secrets detected"
  echo "   Please review your changes and ensure no credentials are being committed."
  echo "   Use environment variables instead."
  exit 1
fi

echo "✅ No secrets detected"
exit 0
