# Server Configuration
PORT=3001
NODE_ENV=development

# Database
# For Supabase: Use pooled connection string
DATABASE_URL=postgresql://postgres.rllhsiguqezuzltsjntp:PE_L-fU69vk!QyK@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres

# JWT - CRITICAL: Generate using: openssl rand -base64 48
# Must be at least 32 characters for security
# DO NOT use default values in production
JWT_SECRET=your_jwt_secret_key_here_must_be_at_least_32_characters_long
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# Frontend
VITE_API_URL=http://localhost:3001/api

# CORS
