# Server Configuration
PORT=3001
NODE_ENV=development

# Database
# For Neon: Use the pooled connection string (port 5432) for regular connections
# DATABASE_URL=postgresql://username:password@ep-xxx-xxx.us-east-1.aws.neon.tech:5432/dbname?sslmode=require
# For connection pooling in serverless environments (Vercel): Use port 6543
DATABASE_URL=postgresql://username:password@ep-xxx-xxx.us-east-1.aws.neon.tech:6543/dbname?sslmode=require

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=7d
BCRYPT_ROUNDS=10

# Frontend
VITE_API_URL=http://localhost:3001/api

# CORS
CORS_ORIGIN=http://localhost:5173

# Email (if needed)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password
SMTP_FROM=noreply@example.com

# File Upload (if needed)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880 # 5MB

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=false
