{
  "name": "i-project-backend",
  "version": "2.0.0",
  "description": "i-Project Backend API - Feature-based Architecture",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node app.js",
    "dev": "dotenv -e .env.development -- node app.js",
    "build": "tsc",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:seed": "dotenv -e .env.development -- node db/seed.js",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@vercel/analytics": "^1.6.1",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "isomorphic-dompurify": "^3.0.0-rc.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.11.5",
    "postgres": "^3.4.7",
    "prisma": "^7.3.0",
    "redis": "^5.11.0",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.19.27",
    "@types/pg": "^8.11.6",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "dotenv-cli": "^7.4.2",
    "drizzle-kit": "^0.18.1",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "typescript": "^5.9.3",
    "vitest": "^1.0.0"
  }
}
