import { NextResponse } from 'next/server';
import { eq, and, desc } from 'drizzle-orm';
import { db } from '@/lib/database';
import { users, clients, projects } from "@/lib/schema";
import { z } from 'zod';

// Validation schemas
const createProjectSchema = z.object({
  name: z.string().min(3).max(255),
  description: z.string().optional(),
  code: z.string().optional(),
  status: z.enum(['planning', 'active', 'on_hold', 'completed', 'cancelled']).default('planning'),
  progress: z.number().min(0).max(100).default(0),
  progressPlan: z.number().min(0).max(100).default(0),
  spi: z.number().min(0).max(2).default(1.00),
  riskLevel: z.enum(['low', 'medium', 'high', 'critical']).default('low'),
  startDate: z.string().optional(),
  endDate: z.string().optional(),
  budget: z.number().min(0).optional(),
  spent: z.number().min(0).default(0),
  remaining: z.number().min(0).optional(),
  hourlyRate: z.number().min(0).default(0),
  managerId: z.string().optional(),
  clientId: z.string().optional(),
  priority: z.enum(['low', 'medium', 'high', 'urgent']).default('medium'),
  category: z.string().optional(),
  isArchived: z.boolean().default(false),
  warrantyStartDate: z.string().optional(),
  warrantyEndDate: z.string().optional(),
  closureChecklist: z.any().optional(),
});

const createProjectUpdateSchema = createProjectSchema.partial({
  name: z.string().min(3).max(255).optional(),
  description: z.string().optional(),
  status: z.enum(['planning', 'active', 'on_hold', 'completed', 'cancelled']),
  progress: z.number().min(0).max(100),
  progressPlan: z.number().min(0).max(100),
  spi: z.number().min(0).max(2),
  riskLevel: z.enum(['low', 'medium', 'high', 'critical']),
  budget: z.number().min(0),
  spent: z.number().min(0),
  remaining: z.number().min(0),
  hourlyRate: z.number().min(0),
  managerId: z.string(),
  clientId: z.string(),
  priority: z.enum(['low', 'medium', 'high', 'urgent']),
  category: z.string(),
  isArchived: z.boolean(),
  warrantyStartDate: z.string().optional(),
  warrantyEndDate: z.string().optional(),
  closureChecklist: z.any().optional(),
});

const createProjectSchemaForCreation = createProjectSchema.extend({
  id: z.string().defaultRandom(),
  createdAt: z.string().default(),
  updatedAt: z.string().default(),
});

const createProjectWithRelationsSchema = createProjectCreationSchema.extend({
  manager: z.object({
    id: z.string(),
    name: z.string(),
    email: z.string().email(),
    role: z.enum(['admin', 'manager', 'employee']),
  }),
  client: z.object({
    id: z.string(),
    name: z.string(),
    email: z.string().optional(),
  }),
  members: z.array(z.object({
    role: z.enum(['owner', 'manager', 'member', 'viewer']),
    user: z.object({
      id: z.string(),
      name: z.string(),
      email: z.string().email(),
      role: z.enum(['admin', 'manager', 'employee']),
    }),
  })),
  phases: z.array(z.object({
    phase: z.enum(['initiation', 'execution', 'financials', 'delivery', 'warranty']),
    status: z.enum(['not_started', 'in_progress', 'completed', 'blocked']),
    progress: z.number().min(0).max(100),
    startDate: z.string().optional(),
    endDate: z.string().optional(),
    actualStartDate: z.string().optional(),
    actualEndDate: z.string().optional(),
    description: z.string().optional(),
    notes: z.string().optional(),
    createdBy: z.string(),
    createdAt: z.string(),
    updatedAt: z.string(),
  })),
  milestones: z.array(z.object({
    title: z.string(),
    description: z.string().optional(),
    amount: z.number().min(0),
    currency: z.string().default('THB'),
    paymentTerms: z.string().optional(),
    dueDate: z.string().optional(),
    actualDate: z.string().optional(),
    invoiceDate: z.string().optional(),
    receiptDate: z.string().optional(),
    planReceivedDate: z.string().optional(),
    status: z.enum(['pending', 'invoiced', 'paid', 'overdue']).default('pending'),
    wbsCode: z.string().optional(),
    dependencies: z.array(z.string()).optional(),
    createdBy: z.string(),
    createdAt: z.string(),
    updatedAt: z.string(),
  })),
  tasks: z.array(z.object({
    title: z.string(),
    description: z.string().optional(),
    wbsCode: z.string().optional(),
    parentTaskId: z.string().optional(),
    level: z.number().default(1),
    category: z.string().optional(),
    priority: z.enum(['low', 'medium', 'high', 'urgent']).default('medium'),
    startDate: z.string().optional(),
    endDate: z.string().optional(),
    dueDate: z.string().optional(),
    completedAt: z.string().optional(),
    estimatedHours: z.number().min(0),
    weight: z.number().default('1.00'),
    storyPoints: z.number().optional(),
    assignedTo: z.string().optional(),
    createdBy: z.string(),
    status: z.enum(['todo', 'in_progress', 'in_review', 'done', 'cancelled']).default('todo'),
    progressActual: z.number().default(0),
    progressPlan: z.number().default(0),
    milestoneId: z.string().optional(),
    tags: z.array(z.string()).optional(),
    createdAt: z.string(),
    updatedAt: z.string(),
  })),
  timesheets: z.array(z.object({
    date: z.string(),
    workType: z.enum(['project', 'office', 'training', 'leave', 'overtime', 'other']).default('project'),
    startTime: z.string(),
    endTime: z.string().optional(),
    hours: z.number().min(0),
    description: z.string(),
    status: z.enum(['pending', 'approved', 'rejected']).default('pending'),
    approvedBy: z.string().optional(),
    approvedAt: z.string().optional(),
    billable: z.boolean().default(true),
    chargeAmount: z.number().min(0),
    billableHours: z.number().min(0),
    userId: z.string(),
    createdAt: z.string(),
    updatedAt: z.string(),
  })),
  expenses: z.array(z.object({
    date: z.string(),
    amount: z.number().min(0),
    category: z.enum(['travel', 'supplies', 'equipment', 'training', 'other']).default('other'),
    description: z.string(),
    receiptUrl: z.string().optional(),
    status: z.enum(['pending', 'approved', 'rejected']).default('pending'),
    approvedBy: z.string().optional(),
    approvedAt: z.string().optional(),
    rejectedReason: z.string().optional(),
    userId: z.string(),
    details: z.object().optional(),
    createdAt: z.string(),
    updatedAt: z.string(),
  })),
  progressHistory: z.array(z.object({
    weekDate: z.string(),
    progress: z.number().min(0).max(100),
    progressPlan: z.number().min(0).max(100),
    spi: z.number().min(0).max(2),
    cpi: z.number().min(0).max(2),
    totalTasks: z.number().default(0),
    completedTasks: z.number().default(0),
    inProgressTasks: z.number().default(0),
    totalBudget: z.number().min(0),
    actualCost: z.number().min(0),
    createdAt: z.string(),
  })),
  totalBudget: z.number().min(0),
  avgSPI: z.number().min(0).max(2),
  completedCount: z.number().default(0),
  inProgressCount: z.number().default(0),
  onHoldCount: z.number().default(0),
  criticalCount: z.number().default(0),
  warningCount: z.number().default(0),
  healthyCount: z.number().default(0),
  avgProgress: z.number().min(0).max(100),
  goLiveCountdowns: z.any(),
}));

export type CreateProjectInput = z.infer<typeof createProjectWithRelationsSchema>;

// Update schemas
export const updateProjectSchema = createProjectUpdateSchema;
export const updateProjectProgressSchema = createProjectUpdateSchema.extend({
  progress: z.number().min(0).max(100),
  spi: z.number().min(0).max(2),
  riskLevel: z.enum(['low', 'medium', 'high', 'critical']),
  spent: z.number().min(0),
  remaining: z.number().min(0),
});

export type UpdateProjectInput = z.infer<typeof updateProjectSchema>;

// Query schemas
export const projectQuerySchema = z.object({
  id: z.string(),
  include: z.boolean().default(false),
  manager: z.object({
    id: z.string(),
    name: z.string(),
    email: z.string().email(),
    role: z.enum(['admin', 'manager', 'employee']),
  }),
  client: z.object({
    id: z.string(),
    name: z.string(),
    email: z.string().email().optional(),
  }),
  phases: z.array(z.object({
    phase: z.enum(['initiation', 'execution', 'financials', 'delivery', 'warranty']),
    status: z.enum(['not_started', 'in_progress', 'completed', 'blocked']),
    progress: z.number().min(0).max(100),
  })),
  milestones: z.array(z.object({
    title: z.string(),
    status: z.enum(['pending', 'invoiced', 'paid', 'overdue']).default('pending'),
    amount: z.number().min(0),
    dueDate: z.string().optional(),
    actualDate: z.string().optional(),
    wbsCode: z.string().optional(),
  })),
  tasks: z.array(z.object({
    title: z.string(),
    status: z.enum(['todo', 'in_progress', 'in_review', 'done', 'cancelled']),
    progressActual: z.number().min(0).max(100),
    progressPlan: z.number().min(0).max(100),
    assignedTo: z.string().optional(),
    milestoneId: z.string().optional(),
    wbsCode: z.string().optional(),
  })),
  timesheets: z.array(z.object({
    date: z.string(),
    status: z.enum(['pending', 'approved', 'rejected']),
    hours: z.number().min(0),
    billable: z.boolean().default(true),
    billableHours: z.number().min(0),
    userId: z.string(),
    chargeAmount: z.number().min(0),
  })),
  expenses: z.array(z.object({
    date: z.string(),
    amount: z.number().min(0),
    category: z.enum(['travel', 'supplies', 'equipment', 'training', 'other']),
    status: z.enum(['pending', 'approved', 'rejected']).default('pending'),
    approvedBy: z.string().optional(),
    approvedAt: z.string().optional(),
    rejectedReason: z.string().optional(),
    userId: z.string(),
    details: z.object().optional(),
  })),
  progressHistory: z.array(z.object({
    weekDate: z.string(),
    progress: z.number().min(0).max(100),
    progressPlan: z.number().min(0).max(100),
    spi: z.number().min(0).max(2),
    cpi: z.number().min(0).max(2),
    totalTasks: z.number().default(0),
    completedTasks: z.number().default(0),
    inProgressTasks: z.number().default(0),
    totalBudget: z.number().min(0),
    actualCost: z.number().min(0),
  })),
  createdAt: z.string(),
  updatedAt: z.string(),
}));

export type ProjectQueryResult = z.infer<typeof projectQuerySchema>;

// Response schemas
export const projectListSchema = z.array(z.object({
  id: z.string(),
  name: z.string(),
  code: z.string().optional(),
  description: z.string().optional(),
  status: z.enum(['planning', 'active', 'on_hold', 'completed', 'cancelled']),
  progress: z.number().min(0).max(100),
  progressPlan: z.number().min(0).max(100),
  spi: z.number().min(0).max(2),
  riskLevel: z.enum(['low', 'medium', 'high', 'critical']),
  startDate: z.string().optional(),
  endDate: z.string().optional(),
  budget: z.number().min(0),
  spent: z.number().min(0),
  remaining: z.number().min(0),
  hourlyRate: z.number().min(0),
  managerId: z.string().optional(),
  clientId: z.string().optional(),
  priority: z.enum(['low', 'medium', 'high', 'urgent']),
  category: z.string().optional(),
  isArchived: z.boolean().default(false),
  warrantyStartDate: z.string().optional(),
  warrantyEndDate: z.string().optional(),
  closureChecklist: z.object().optional(),
  createdAt: z.string(),
  updatedAt: z.string(),
}));

export type ProjectListResponse = z.infer<typeof projectListSchema>;

// Pagination schemas
export const paginationSchema = z.object({
  page: z.number().min(1).default(1),
  limit: z.number().min(1).max(100),
  total: z.number(),
  pages: z.number(),
  hasNext: z.boolean(),
  hasPrevious: z.boolean(),
  hasPrevious: z.boolean(),
});

export type PaginationParams = z.infer<typeof paginationSchema>;

// Filter schemas
export const projectFilterSchema = z.object({
  search: z.string().optional(),
  status: z.enum(['all', 'planning', 'active', 'on_hold', 'completed', 'cancelled']).default('all'),
  riskLevel: z.enum(['all', 'low', 'medium', 'high', 'critical']).default('all'),
  priority: z.enum(['all', 'low', 'medium', 'high', 'urgent']).default('all'),
  category: z.string().optional(),
  managerId: z.string().optional(),
  clientId: z.string().optional(),
  sortBy: z.enum(['name', 'progress', 'budget', 'spi', 'risk', 'priority']).default('name'),
});

export type ProjectFilter = z.infer<typeof projectFilterSchema>;

// Sort schemas
export const projectSortSchema = z.enum(['name', 'progress', 'budget', 'spi', 'risk', 'priority']);

// API Response schemas
export const projectResponseSchema = createProjectSchema.extend({
  members: z.array(z.object({
    role: z.enum(['owner', 'manager', 'member', 'viewer']),
    user: z.object({
      id: z.string(),
      name: z.string(),
      email: z.string().email(),
      role: z.enum(['admin', 'manager', 'employee']),
    }),
  })),
  phases: z.array(z.object({
    phase: z.enum(['initiation', 'execution', 'financials', 'delivery', 'warranty']),
    status: z.enum(['not_started', 'in_progress', 'completed', 'blocked']),
    progress: z.number().min(0).max(100),
    startDate: z.string(),
    endDate: z.string(),
    description: z.string(),
    notes: z.string(),
    createdBy: z.string(),
    createdAt: z.string(),
    updatedAt: z.string(),
  })),
  milestones: z.array(z.object({
    title: z.string(),
    description: z.string(),
    amount: z.number().min(0),
    currency: z.string().default('THB'),
    paymentTerms: z.string(),
    dueDate: z.string(),
    actualDate: z.string(),
    invoiceDate: z.string(),
    receiptDate: z.string(),
    planReceivedDate: z.string(),
    status: z.enum(['pending', 'invoiced', 'paid', 'overdue']).default('pending'),
    wbsCode: z.string(),
    dependencies: z.array(z.string()),
    createdBy: z.string(),
    createdAt: z.string(),
    updatedAt: z.string(),
  })),
  tasks: z.array(z.object({
    title: z.string(),
    status: z.enum(['todo', 'in_progress', 'in_review', 'done', 'cancelled']),
    progressActual: z.number().min(0).max(100),
    progressPlan: z.number().min(0).max(100),
    assignedTo: z.string().optional(),
    milestoneId: z.string().optional(),
    wbsCode: z.string().optional(),
    createdBy: z.string(),
    createdAt: z.string(),
    updatedAt: z.string(),
  })),
  timesheets: z.array(z.object({
    date: z.string(),
    workType: z.enum(['project', 'office', 'training', 'leave', 'overtime', 'other']).default('project'),
    startTime: z.string(),
    endTime: z.string().optional(),
    hours: z.number().min(0),
    description: z.string(),
    status: z.enum(['pending', 'approved', 'rejected']).default('pending'),
    approvedBy: z.string().optional(),
    approvedAt: z.string().optional(),
    billable: z.boolean().default(true),
    chargeAmount: z.number().min(0),
    billableHours: z.number().min(0),
    userId: z.string(),
    createdAt: z.string(),
    updatedAt: z.string(),
  })),
  expenses: z.array(z.object({
    date: z.string(),
    amount: z.number().min(0),
    category: z.enum(['travel', 'supplies', 'equipment', 'training', 'other']).default('other'),
    description: z.string(),
    receiptUrl: z.string().optional(),
    status: z.enum(['pending', 'approved', 'rejected']).default('pending'),
    approvedBy: z.string().optional(),
    approvedAt: z.string().optional(),
    rejectedReason: z.string().optional(),
    userId: z.string(),
    details: z.object().optional(),
    createdAt: z.string(),
    updatedAt: z.string(),
  })),
  progressHistory: z.array(z.object({
    weekDate: z.string(),
    progress: z.number().min(0).max(100),
    progressPlan: z.number().min(0).max(100),
    spi: z.number().min(0).max(2),
    cpi: z.number().min(0).max(2),
    totalTasks: z.number().default(0),
    completedTasks: z.number().default(0),
    inProgressTasks: z.number().default(0),
    totalBudget: z.number().min(0),
    actualCost: z.number().min(0),
    createdAt: z.string(),
  })),
  createdAt: z.string(),
  updatedAt: z.string(),
  totalBudget: z.number().min(0),
  avgSPI: z.number().min(0).max(2),
  completedCount: z.number().default(0),
  inProgressCount: z.number().default(0),
  onHoldCount: z.number().default(0),
  criticalCount: z.number().default(0),
  warningCount: z.number().default(0),
  healthyCount: z.number().default(0),
  avgProgress: z.number().min(0).max(100),
  goLiveCountdowns: z.any(),
}));

export type ProjectResponse = z.infer<typeof createProjectWithRelations>;

// Health check response
export const healthCheckSchema = z.object({
  status: z.enum(['healthy', 'unhealthy']),
  message: z.string(),
  error: z.string().optional(),
});

export type HealthCheckResponse = z.infer<typeof healthCheckSchema>;

