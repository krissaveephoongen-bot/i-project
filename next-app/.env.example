 # Supabase connection for Prisma (use the Connection Pooler)
 # Format:
 # postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
 # Example:
 # DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@aws-xxx.pooler.supabase.com:5432/postgres?sslmode=require
 #
 # Notes:
 # - Use the Pooler host (ends with .pooler.supabase.com), not the direct DB host
 # - Keep sslmode=require
 # - Avoid special characters without URL-encoding in USER/PASSWORD
 
 DATABASE_URL=
