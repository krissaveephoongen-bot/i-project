generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USER RELATED ENUMS
// ============================================================

enum user_role {
  admin
  manager
  employee
  vendor
}

enum user_status {
  active
  inactive
}

// ============================================================
// PROJECT RELATED ENUMS
// ============================================================

enum Status {
  todo
  in_progress
  in_review
  done
  pending
  approved
  rejected
  active
  inactive
}

enum Priority {
  low
  medium
  high
}

enum ActivityType {
  create
  update
  delete
  comment
  assign
  status_change
}

enum WorkType {
  project
  office
  other
}

enum ExpenseCategory {
  travel
  supplies
  equipment
  training
  other
}

enum ExpenseStatus {
  pending
  approved
  rejected
  reimbursed
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

enum ApprovalActionType {
  project_manager_approval
  supervisor_approval
}

// ============================================================
// MODELS
// ============================================================

model users {
  id                        String    @id @default(cuid())
  objectId                  String?   @unique
  name                      String
  email                     String    @unique
  password                  String?
  role                      user_role @default(employee)
  avatar                    String?
  department                String?
  position                  String?
  employeeCode              String?
  hourlyRate                Decimal   @default(0.00) @db.Decimal(10, 2)
  phone                     String?
  status                    String    @default("active")
  isActive                  Boolean   @default(true)
  isDeleted                 Boolean   @default(false)
  isProjectManager          Boolean   @default(false)
  isSupervisor              Boolean   @default(false)
  failedLoginAttempts       Int       @default(0)
  lastLogin                 DateTime?
  lockedUntil               DateTime?
  resetToken                String?
  resetTokenExpiry          DateTime?
  notificationPreferences   Json?
  timezone                  String    @default("Asia/Bangkok")
  name_th                   String?
  weeklyCapacity            Decimal?  @default(40.00) @db.Decimal(5, 2)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  // Relations
  projects                  projects[]
  clients                   clients[]
  tasks                     tasks[]
  timeEntries               time_entries[]
  expenses                  expenses[]
  comments                  comments[]
  documents                 documents[]
  activityLog               activity_log[]
  budgetRevisions           budget_revisions[]
  projectMemberships       project_members[]
  risks                     risks[]
  contacts                  contacts[]
  approvalActions           approval_actions[]
  timesheetApprovalActions  timesheet_approval_actions[]
  vendorKpiEvaluations      vendor_kpi_evaluations[]
  resourceAllocations       resource_allocations[]
  leaveAllocations          leave_allocations[]
  leaveRequestsUser         leave_requests[]
  leaveRequestsApprover     leave_requests[]
  timeEntryComments         time_entry_comments[]
  vendorContracts           vendor_contracts[]
  vendorPayments            vendor_payments[]
  teamStructure             team_structure[]
  approvalRequests          approval_requests[]
  approvalWorkflows         approval_workflows[]
  expenseItems              expense_items[]
  timesheets                timesheets[]
  projectProgressHistory    project_progress_history[]
  projectProgressSnapshots  project_progress_snapshots[]
  salesActivities           sales_activities[]
  salesDeals                sales_deals[]
  savedViews                saved_views[]
  auditLogs                 audit_logs[]
  financialData             financial_data[]
  systemSettings            system_settings[]
  stakeholders              stakeholders[]
  taskActualLogs            task_actual_logs[]
  taskPlanPoints            task_plan_points[]
  timesheetSubmissions      timesheet_submissions[]
  spiCpiDailySnapshot       spi_cpi_daily_snapshot[]
}

model clients {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  taxId     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  projects  projects[]
  contacts  contacts[]
  salesDeals sales_deals[]
}

model projects {
  id              String    @id @default(cuid())
  name            String
  code            String?   @unique
  description     String?
  status          Status    @default(todo)
  progress        Int       @default(0)
  progressPlan    Int       @default(0)
  spi             Decimal   @default(1.00) @db.Decimal(5, 2)
  riskLevel       String    @default("low")
  startDate       DateTime?
  endDate         DateTime?
  budget          Decimal?  @db.Decimal(12, 2)
  spent           Decimal   @default(0.00) @db.Decimal(12, 2)
  remaining       Decimal   @default(0.00) @db.Decimal(12, 2)
  managerId       String?
  clientId        String?
  hourlyRate      Decimal   @default(0.00) @db.Decimal(10, 2)
  priority        String    @default("medium")
  category        String?
  isArchived      Boolean   @default(false)
  closureChecklist Json?
  warrantyStartDate DateTime? @db.Timestamp(6)
  warrantyEndDate   DateTime? @db.Timestamp(6)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  manager      users?        @relation(fields: [managerId], references: [id])
  client       clients?      @relation(fields: [clientId], references: [id])
  tasks        tasks[]
  milestones   milestones[]
  timeEntries  time_entries[]
  expenses     expenses[]
  documents    documents[]
  contacts     contacts[]
  budgetRevisions budget_revisions[]
  projectMemberships project_members[]
  risks        risks[]
  resourceAllocations resource_allocations[]
  vendorContracts vendor_contracts[]
  vendorPayments vendor_payments[]
  vendorKpiEvaluations vendor_kpi_evaluations[]
  teamStructure team_structure[]
  approvalRequests approval_requests[]
  expenseItems expense_items[]
  timesheets timesheets[]
  projectProgressHistory project_progress_history[]
  projectProgressSnapshots project_progress_snapshots[]
  auditLogs audit_logs[]
  activityLog activity_log[]
  spiCpiDailySnapshot spi_cpi_daily_snapshot[]
}

model tasks {
  id             String    @id @default(cuid())
  title          String
  description    String?
  status         Status    @default(todo)
  priority       Priority  @default(medium)
  dueDate        DateTime?
  estimatedHours Decimal?  @db.Decimal(6, 2)
  actualHours    Decimal   @default(0.00) @db.Decimal(6, 2)
  weight         Decimal   @default(1.00) @db.Decimal(10, 2)
  completedAt    DateTime?
  projectId      String
  assignedTo     String?
  createdBy      String
  parentTaskId   String?
  category       String?
  storyPoints    Int?
  blockedBy      String?
  blockedReason  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  project        projects  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee       users?    @relation(fields: [assignedTo], references: [id])
  creator        users     @relation(fields: [createdBy], references: [id])
  parentTask     tasks?    @relation("SubTasks", fields: [parentTaskId], references: [id])
  subTasks       tasks[]   @relation("SubTasks")
  comments       comments[]
  documents      documents[]
  timeEntries    time_entries[]
  expenses       expenses[]
  taskActualLogs task_actual_logs[]
  taskPlanPoints task_plan_points[]
}

model time_entries {
  id                    String     @id @default(cuid())
  date                  DateTime
  workType              WorkType
  projectId             String?
  taskId                String?
  userId                String
  startTime             String
  endTime               String?
  hours                 Decimal    @db.Decimal(5, 2)
  description           String?
  status                Status     @default(pending)
  approvedBy            String?
  approvedAt            DateTime?
  rejectedReason        String?
  isConcurrent          Boolean    @default(false)
  concurrentEntryIds    String[]   @default([])
  concurrentReason      String?
  breakDuration         Int        @default(60)
  chargeable            Boolean    @default(false)
  chargeAmount          Decimal?   @db.Decimal(12, 2)
  billableHours         Decimal?   @db.Decimal(5, 2)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  // Relations
  project        projects?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task           tasks?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  user           users      @relation(fields: [userId], references: [id], onDelete: Cascade)
  approver       users?     @relation(fields: [approvedBy], references: [id])
  timeEntryComments time_entry_comments[]
  timesheets timesheets[]
}

model expenses {
  id            String          @id @default(cuid())
  date          DateTime
  projectId     String
  taskId        String?
  userId        String
  amount        Decimal         @db.Decimal(12, 2)
  category      ExpenseCategory
  description   String
  receiptUrl    String?
  status        ExpenseStatus   @default(pending)
  approvedBy    String?
  approvedAt    DateTime?
  notes         String?
  rejectedReason String?
  details       Json?
  approverId    String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Relations
  project       projects       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task          tasks?          @relation(fields: [taskId], references: [id], onDelete: SetNull)
  user          users           @relation(fields: [userId], references: [id], onDelete: Cascade)
  approver      users?          @relation(fields: [approvedBy], references: [id])
  approverUser  users?          @relation(fields: [approverId], references: [id])
  expenseItems  expense_items[]
}

model milestones {
  id          String    @id @default(cuid())
  title       String
  name        String?
  description String?
  dueDate     DateTime
  amount      Decimal?  @db.Decimal(15, 2)
  percentage  Decimal?  @default(0.00) @db.Decimal
  status      String    @default("pending")
  progress    Int       @default(0)
  projectId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  project      projects? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  tasks        tasks[]
}

model comments {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  taskId    String
  userId    String
  task      tasks    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      users    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model documents {
  id         String   @id @default(cuid())
  name       String
  type       String?
  size       String?
  url        String?
  milestone  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  projectId  String?
  taskId     String?
  uploadedBy String?

  project    projects? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task       tasks?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  uploader   users?    @relation(fields: [uploadedBy], references: [id])
}

model activity_log {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String
  type        ActivityType
  action      String
  description String?
  changes     Json?
  createdAt   DateTime @default(now())

  // Relations
  userId      String
  user        users    @relation(fields: [userId], references: [id])
}

model budget_revisions {
  id             String   @id @default(cuid())
  previousBudget Decimal  @db.Decimal(12, 2)
  newBudget      Decimal  @db.Decimal(12, 2)
  reason         String
  changedAt      DateTime @default(now())

  // Relations
  projectId      String
  changedBy      String
  project        projects  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  changer        users     @relation(fields: [changedBy], references: [id])
}

model project_members {
  id        String   @id @default(cuid())
  role      String   @default("member")
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  projectId String
  userId    String
  project   projects  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      users     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model project_progress_history {
  id        String   @id @default(cuid())
  progress  Int
  weekDate  DateTime
  createdAt DateTime @default(now())

  // Relations
  projectId String
  project   projects  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model risks {
  id             String    @id @default(cuid())
  title          String
  description    String?
  impact         String
  probability    String
  riskScore      Int?
  mitigationPlan String?
  status         String    @default("open")
  projectId      String?
  assignedTo     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  project        projects? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignee       users?    @relation(fields: [assignedTo], references: [id])
}

// ============================================================
// VENDOR MANAGEMENT
// ============================================================

model vendors {
  id                   String    @id @default(cuid())
  name                 String
  code                 String?
  type                 String    // 'supplier', 'contractor', 'service'
  category             String?
  status               String    @default("active")
  contactPerson        String?
  email                String?
  phone                String?
  website              String?
  taxId                String?
  registrationNumber   String?
  address              String?
  city                 String?
  province             String?
  postalCode           String?
  country              String?
  bankAccount          String?
  bankName             String?
  paymentTerms         Int?
  creditLimit          Decimal?  @db.Decimal(15, 2)
  notes                String?
  overallRating        Decimal?  @db.Decimal(5, 2)
  onTimeDeliveryRate   Decimal?  @db.Decimal(5, 2)
  totalProjects        Int       @default(0)
  successfulProjects   Int       @default(0)
  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Relations
  contracts      vendor_contracts[]
  payments       vendor_payments[]
  kpiEvaluations vendor_kpi_evaluations[]
}

model vendor_contracts {
  id            String    @id @default(cuid())
  vendorId      String
  projectId     String
  contractNumber String   @notNull
  title         String
  description   String?
  type          String?
  startDate     DateTime
  endDate       DateTime?
  value         Decimal   @db.Decimal(15, 2)
  currency      String    @default("THB")
  paymentTerms  String?
  paymentSchedule String?
  status        String    @default("active")
  signedDate    DateTime?
  signedBy      String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  vendor        vendors    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  project       projects  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  signer        users?     @relation(fields: [signedBy], references: [id])
  payments      vendor_payments[]
  kpiEvaluations vendor_kpi_evaluations[]
}

model vendor_payments {
  id               String    @id @default(cuid())
  vendorId         String
  contractId       String?
  projectId        String
  paymentType      String    // 'milestone', 'installment', 'final'
  amount           Decimal   @db.Decimal(15, 2)
  currency         String    @default("THB")
  dueDate          DateTime
  paidDate         DateTime?
  status           String    @default("pending")
  paymentMethod    String?
  transactionId    String?
  receiptUrl       String?
  description      String?
  installmentNumber Int?
  totalInstallments Int?
  approvedBy       String?
  approvedAt       DateTime?
  rejectedReason   String?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  vendor        vendors        @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  contract      vendor_contracts? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  project       projects       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  approver      users?         @relation(fields: [approvedBy], references: [id])
}

model vendor_kpi_evaluations {
  id              String    @id @default(cuid())
  vendorId        String
  contractId      String?
  projectId       String
  evaluationPeriod String    // 'monthly', 'quarterly', 'project_end'
  qualityScore     Decimal   @db.Decimal(5, 2)
  timelinessScore  Decimal   @db.Decimal(5, 2)
  costScore        Decimal   @db.Decimal(5, 2)
  communicationScore Decimal @db.Decimal(5, 2)
  overallScore     Decimal   @db.Decimal(5, 2)
  comments        String?
  evaluatedBy     String
  evaluationDate  DateTime @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  vendor        vendors        @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  contract      vendor_contracts? @relation(fields: [contractId], references: [id], onDelete: Cascade)
  project       projects       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  evaluator     users          @relation(fields: [evaluatedBy], references: [id])
}

// ============================================================
// APPROVAL SYSTEM
// ============================================================

model approval_workflows {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String    // 'timesheet', 'expense', 'task', 'purchase_order'
  requiredRole String   // 'manager', 'admin', 'finance'
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  requests    approval_requests[]
}

model approval_requests {
  id          String           @id @default(cuid())
  type        String           // 'timesheet', 'expense', 'task', 'purchase_order'
  requestId   String
  title       String
  description String?
  requestedBy String
  requestedAt DateTime         @default(now())
  status      ApprovalStatus    @default(pending)
  priority    String           @default("medium")
  amount      Decimal?         @db.Decimal(15, 2)
  currency    String           @default("THB")
  projectId   String?
  workflowId  String?
  metadata    Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // Relations
  requester   users             @relation(fields: [requestedBy], references: [id])
  project     projects?         @relation(fields: [projectId], references: [id])
  workflow    approval_workflows? @relation(fields: [workflowId], references: [id])
  actions     approval_actions[]
}

model approval_actions {
  id          String             @id @default(cuid())
  requestId   String
  actionBy    String
  action      ApprovalActionType
  comments    String?
  actionAt    DateTime           @default(now())
  createdAt   DateTime           @default(now())

  // Relations
  request     approval_requests @relation(fields: [requestId], references: [id], onDelete: Cascade)
  actor       users              @relation(fields: [actionBy], references: [id])
}

// ============================================================
// ADDITIONAL MODELS FOR COMPLETENESS
// ============================================================

model contacts {
  id            String    @id @default(cuid())
  name          String
  position      String?
  email         String?
  phone         String?
  department    String?
  type          String    // 'client', 'stakeholder', 'team_member'
  clientId      String?
  projectId     String?
  userId        String?
  isKeyPerson   Boolean   @default(false)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  client       clients?  @relation(fields: [clientId], references: [id])
  project      projects? @relation(fields: [projectId], references: [id])
  user         users?    @relation(fields: [userId], references: [id])
  salesDeals   sales_deals[]
}

model team_structure {
  id              String    @id @default(cuid())
  projectId       String
  userId          String
  role            String    // 'project_manager', 'team_lead', 'developer', 'designer', etc.
  level           Int       @default(1)
  parentId        String?
  responsibilities String?
  startDate       DateTime?
  endDate         DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  project        projects  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user           users     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent         team_structure? @relation("TeamHierarchy", fields: [parentId], references: [id])
  children       team_structure[] @relation("TeamHierarchy")
}

model expense_items {
  id               String    @id @default(cuid())
  expenseId        String
  vendorId         String?
  category         String
  subcategory      String?
  description      String
  quantity         Decimal   @default(1.00) @db.Decimal(10, 2)
  unitPrice        Decimal   @db.Decimal(12, 2)
  totalPrice       Decimal   @db.Decimal(12, 2)
  vendorItemCode   String?
  vendorInvoice    String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  expense          expenses  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  vendor           vendors?  @relation(fields: [vendorId], references: [id])
}

model timesheets {
  id              String    @id @default(cuid())
  userId          String
  projectId       String
  taskId          String?
  date            DateTime  @db.Date
  hours           Decimal?  @default(0) @db.Decimal
  startTime       DateTime? @db.Timestamp(6)
  endTime         DateTime? @db.Timestamp(6)
  status          String    @default("pending")
  description     String?
  rejectedReason  String?
  approvedBy      String?
  approvedAt      DateTime? @db.Timestamp(6)
  billable        Boolean?  @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  user            users     @relation(fields: [userId], references: [id])
  project         projects  @relation(fields: [projectId], references: [id])
  task            tasks?    @relation(fields: [taskId], references: [id])
  approver        users?    @relation(fields: [approvedBy], references: [id])
  timeEntries     time_entries[]
}

model timesheet_approval_actions {
  id              String    @id @default(cuid())
  timesheetId     String
  actionType      ApprovalActionType
  previousStatus  ApprovalStatus
  newStatus       ApprovalStatus
  changedBy       String
  reason          String?
  createdAt       DateTime  @default(now())

  // Relations
  timesheet       timesheets @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  changer         users      @relation(fields: [changedBy], references: [id])
}

model project_progress_snapshots {
  id             String    @id @default(cuid())
  projectId      String
  date           DateTime  @db.Date
  planPercent    Decimal   @default(0) @db.Decimal
  actualPercent  Decimal   @default(0) @db.Decimal
  spi            Decimal?  @db.Decimal
  createdAt      DateTime  @default(now())

  // Relations
  project        projects  @relation(fields: [projectId], references: [id], onDelete: NoAction)
}

model resource_allocations {
  id            String    @id @default(cuid())
  userId        String
  projectId     String
  hoursPerWeek  Decimal   @db.Decimal(5, 2)
  startDate     DateTime  @db.Date
  endDate       DateTime  @db.Date
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  user          users     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project       projects  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// Add other necessary models as needed...
model sales_deals {
  id               String    @id @default(cuid())
  name             String
  amount           Decimal   @default(0) @db.Decimal(14, 2)
  currency         String    @default("THB")
  pipelineId       String?
  stageId          String?
  ownerId          String?
  clientId         String?
  clientOrg        String?
  status           String    @default("open")
  probability      Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  owner            users?           @relation(fields: [ownerId], references: [id])
  client           contacts?        @relation(fields: [clientId], references: [id])
  contacts         contacts[]
  salesActivities  sales_activities[]
}

model sales_activities {
  id          String    @id @default(cuid())
  dealId      String
  type        String
  note        String?
  userId      String?
  createdAt   DateTime  @default(now())

  // Relations
  deal        sales_deals @relation(fields: [dealId], references: [id])
  user        users?      @relation(fields: [userId], references: [id])
}

model time_entry_comments {
  id          String   @id @default(cuid())
  timeEntryId String
  userId      String
  content     String
  createdAt   DateTime @default(now())

  // Relations
  timeEntry   time_entries @relation(fields: [timeEntryId], references: [id], onDelete: Cascade)
  user        users        @relation(fields: [userId], references: [id])
}

// Add placeholder models for missing relations
model leave_allocations {
  id        String   @id @default(cuid())
  userId    String
  leaveType String
  year      Int
  totalDays Int
  usedDays  Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
